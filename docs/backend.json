
{
  "entities": {
    "Organizer": {
      "title": "Organizador",
      "description": "Informações do promotor do evento",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string", "description": "Nome de usuário único, min 5 chars, alfanumérico" },
        "avatar": { "type": "string" },
        "email": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "prefiro não dizer", "empresa"] },
        "showEmail": { "type": "boolean", "description": "Define se o e-mail é visível publicamente" },
        "bio": { "type": "string", "description": "Máximo 150 caracteres, sem links" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "website": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "followersCount": { "type": "number" },
        "rating": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "totalEvents": { "type": "number" },
        "platform": { "type": "string", "enum": ["viby"] },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "accountType": { "type": "string", "enum": ["Usuário", "Empresa"] },
        "businessCategory": { "type": "string" },
        "legalName": { "type": "string", "description": "Razão Social" },
        "cnpj": { "type": "string" }
      },
      "required": ["name", "email", "username", "platform", "city", "state", "country", "accountType", "birthDate", "gender"]
    },
    "Username": {
      "title": "Unicidade de Usuário",
      "description": "Mapeamento para garantir nomes de usuário únicos",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Follow": {
      "title": "Seguidor",
      "description": "Relacionamento de seguimento entre usuários",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    },
    "Event": {
      "title": "Evento",
      "description": "Informações do evento para divulgação",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string", "enum": ["Público", "Privado", "Governo"] },
        "status": { "type": "string", "enum": ["A fazer", "Em progresso", "Concluído", "Excluído"] },
        "image": { "type": "string" },
        "organizerId": { "type": "string" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isFree": { "type": "boolean" },
        "organizer": { "$ref": "#/backend/entities/Organizer" }
      },
      "required": ["title", "date", "location", "organizerId"]
    },
    "Registration": {
      "title": "Participação",
      "description": "Registro de interesse de um usuário em um evento",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userGender": { "type": "string" },
        "userBirthDate": { "type": "string", "format": "date" },
        "organizerId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "batchName": { "type": "string" },
        "checkedIn": { "type": "boolean" },
        "paymentStatus": { "type": "string", "enum": ["Disponível", "Pendente", "Pago", "Expirado"] },
        "ticketCode": { "type": "string", "description": "Código de 16 caracteres formatado XXXX-XXXX-XXXX-XXXX" },
        "couponCode": { "type": "string" }
      },
      "required": ["eventId", "userId", "organizerId"]
    },
    "Coupon": {
      "title": "Cupom de Desconto",
      "description": "Cupons de desconto para ingressos de eventos",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed", "free_ticket"] },
        "discountValue": { "type": "number" },
        "maxUses": { "type": "number" },
        "currentUses": { "type": "number" },
        "eventId": { "type": "string" },
        "organizerId": { "type": "string" },
        "validFrom": { "type": "string", "format": "date-time" },
        "validUntil": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] }
      },
      "required": ["code", "discountType", "discountValue", "eventId", "organizerId"]
    },
    "Category": {
      "title": "Categoria",
      "description": "Categorias de classificação para eventos",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "SiteSettings": {
      "title": "Configurações do Site",
      "description": "Configurações globais de identidade visual",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "iconUrl": { "type": "string" }
      },
      "required": ["siteName"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Coleção global de eventos Viby"
    },
    "/users/{userId}": {
      "schema": "Organizer",
      "description": "Perfis dos organizadores Viby"
    },
    "/usernames/{username}": {
      "schema": "Username",
      "description": "Índice de nomes de usuário para garantir unicidade"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Relacionamentos de seguimento entre usuários"
    },
    "/registrations/{regId}": {
      "schema": "Registration",
      "description": "Interesses registrados nos eventos Viby"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Cupons de desconto gerenciados pelos organizadores"
    },
    "/categories/{catId}": {
      "schema": "Category",
      "description": "Categorias de eventos gerenciadas por admins"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Configurações globais de identidade visual"
    }
  }
}
