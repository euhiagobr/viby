
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil individual do usuário unificado",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "email": { "type": "string" },
        "cpf": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "platform": { "type": "string", "enum": ["viby"] },
        "status": { "type": "string", "enum": ["Ativo", "Bloqueado"] }
      },
      "required": ["name", "email", "username", "platform"]
    },
    "Organization": {
      "title": "Organização",
      "description": "Entidade administradora de eventos (Empresa, ONG, Artista, etc)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "type": { "type": "string", "enum": ["empresa", "ong", "artista", "coletivo", "produtora", "casa_noturna", "orgao_publico", "outro"] },
        "isVerified": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["START", "PRO", "TOP"] },
        "legalName": { "type": "string" },
        "cnpj": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "bank": { "type": "string" },
            "branch": { "type": "string" },
            "account": { "type": "string" },
            "pixKey": { "type": "string" }
          }
        },
        "stripeId": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "verified"] }
      },
      "required": ["name", "username", "type", "plan"]
    },
    "OrganizationMember": {
      "title": "Membro da Organização",
      "description": "Vínculo de permissão entre Usuário e Organização",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "editor"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "userId", "role"]
    },
    "Event": {
      "title": "Evento",
      "description": "Informações do evento vinculado a uma organização",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "city": { "type": "string" },
        "organizationId": { "type": "string" },
        "status": { "type": "string" },
        "image": { "type": "string" },
        "isFree": { "type": "boolean" },
        "organization": { "$ref": "#/backend/entities/Organization" }
      },
      "required": ["title", "date", "organizationId"]
    },
    "Registration": {
      "title": "Inscrição/Ingresso",
      "description": "Voucher de participação de um usuário em um evento",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "organizationId": { "type": "string" },
        "attendeeName": { "type": "string" },
        "attendeeCPF": { "type": "string" },
        "ticketCode": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["eventId", "userId", "organizationId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Coleção de perfis de usuários"
    },
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Coleção de organizações/produtores"
    },
    "/organization_members/{memberId}": {
      "schema": "OrganizationMember",
      "description": "Mapeamento de permissões"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Eventos vinculados a organizações"
    },
    "/registrations/{regId}": {
      "schema": "Registration",
      "description": "Ingressos emitidos"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Usuários seguindo organizações"
    }
  }
}
