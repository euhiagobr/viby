
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado deterministicamente" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "website": { "type": "string" },
        "showEmail": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "UserGamification": {
      "title": "Gamificação do Usuário",
      "description": "Dados de progresso, XP e nível",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currentXp": { "type": "number", "default": 0 },
        "totalXp": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "levelName": { "type": "string" },
        "nextLevelXp": { "type": "number" },
        "lastActivityAt": { "type": "string", "format": "date-time" }
      }
    },
    "CulturalStats": {
      "title": "Estatísticas Culturais",
      "description": "Perfil de consumo cultural do usuário",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topCategory": { "type": "string" },
        "topNeighborhood": { "type": "string" },
        "topCity": { "type": "string" },
        "totalEvents": { "type": "number" },
        "totalCheckins": { "type": "number" },
        "categoriesExplored": { "type": "array", "items": { "type": "string" } },
        "neighborhoodsExplored": { "type": "array", "items": { "type": "string" } },
        "favoriteOrganizers": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Identidade pessoal e configurações"
    },
    "/user_gamification/{userId}": {
      "schema": "UserGamification",
      "description": "Progresso de gamificação por usuário"
    },
    "/cultural_stats/{userId}": {
      "schema": "CulturalStats",
      "description": "Perfil cultural e estatísticas por usuário"
    },
    "/levels/{levelId}": {
      "schema": "object",
      "description": "Configuração dos níveis de progressão"
    },
    "/badges/{badgeId}": {
      "schema": "object",
      "description": "Configuração de medalhas e conquistas"
    },
    "/user_badges/{userBadgeId}": {
      "schema": "object",
      "description": "Associação entre usuários e medalhas conquistadas"
    },
    "/xp_rules/{ruleId}": {
      "schema": "object",
      "description": "Regras automáticas de ganho de XP"
    },
    "/xp_logs/{logId}": {
      "schema": "object",
      "description": "Histórico detalhado de ganhos de XP"
    },
    "/tax_ads/{taxId}": {
      "schema": "TaxAd",
      "description": "Registros de impostos de anúncios"
    },
    "/tax_tickets/{taxId}": {
      "schema": "TaxTicket",
      "description": "Registros de impostos de ingressos"
    },
    "/payout_requests/{requestId}": {
      "schema": "PayoutRequest",
      "description": "Solicitações de saque das organizações"
    }
  }
}
