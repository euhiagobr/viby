
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "agênero", "gênero fluido", "bigênero", "demigênero", "homem trans", "mulher trans", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "walletBalance": { "type": "number", "description": "Saldo em reais disponível para uso na plataforma" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "WalletTransaction": {
      "title": "Transação de Carteira",
      "description": "Registro de crédito ou débito na carteira do usuário",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "reason": { "type": "string", "description": "Motivo (ex: estorno_ingresso, compra_ingresso)" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notificação",
      "description": "Alertas de sistema, menções e interações sociais",
      "type": "object",
      "properties": {
        "targetUid": { "type": "string", "description": "UID do destinatário" },
        "senderId": { "type": "string", "description": "UID do remetente" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["mention", "follow", "system"] },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PasswordResetCode": {
      "title": "Código de Recuperação",
      "description": "OTP para troca de senha",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "used": { "type": "boolean" },
        "usedAt": { "type": "string", "format": "date-time" },
        "attempts": { "type": "number" },
        "ip": { "type": "string" },
        "userAgent": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários"
    },
    "/wallet_transactions/{txId}": {
      "schema": "WalletTransaction",
      "description": "Extrato de créditos e débitos dos usuários"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Central de notificações e menções"
    },
    "/password_reset_codes/{docId}": {
      "schema": "PasswordResetCode",
      "description": "Tokens de segurança para recuperação de senha"
    }
  }
}
