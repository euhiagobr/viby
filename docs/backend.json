
{
  "entities": {
    "CrmCampaign": {
      "title": "Campanha de Marketing",
      "description": "Campanha de e-mail marketing gerada via IA com fluxo de aprovação.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "objective": { "type": "string" },
        "basePublic": { "type": "string", "enum": ["users", "buyers", "organizers", "leads", "attendees"] },
        "filters": { "type": "object" },
        "status": { "type": "string", "enum": ["rascunho", "teste_enviado", "aprovado", "agendado", "enviando", "concluido"] },
        "subject": { "type": "string" },
        "preheader": { "type": "string" },
        "contentHtml": { "type": "string" },
        "targetCount": { "type": "number" },
        "selectedEventIds": { "type": "array", "items": { "type": "string" } },
        "brandVersion": { "type": "number" },
        "createdBy": { "type": "string" },
        "approvedBy": { "type": "string" },
        "metrics": {
          "type": "object",
          "properties": {
            "sent": { "type": "number" },
            "delivered": { "type": "number" },
            "opens": { "type": "number" },
            "clicks": { "type": "number" },
            "conversions": { "type": "number" },
            "revenue": { "type": "number" }
          }
        }
      }
    },
    "BrandKnowledge": {
      "title": "Conhecimento da Marca",
      "description": "Dados mestres da identidade Viby para orientação da IA.",
      "type": "object",
      "properties": {
        "identity": { "type": "object" },
        "visual": { "type": "object" },
        "urls": { "type": "object" },
        "contacts": { "type": "object" },
        "footerTemplate": { "type": "string" },
        "version": { "type": "number" }
      }
    },
    "CityPage": {
      "title": "Página de Cidade",
      "description": "Metadados e mídias de páginas de destino de cidades para SEO.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "coverImage": { "type": "string" },
        "coverGeneratedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "RecurringOccurrence": {
      "title": "Ocorrência de Evento",
      "description": "Sessão individual de um evento recorrente.",
      "type": "object",
      "properties": {
        "parentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "cancelled"] },
        "capacidadeMaxima": { "type": "number" },
        "ingressosVendidos": { "type": "number" },
        "batches": { 
          "type": "array", 
          "description": "Opcional. Se presente, sobrescreve a bilheteria global do evento pai para esta sessão.",
          "items": { "type": "object" } 
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "google", "facebook"]
  },
  "firestore": {
    "/crm_campaigns/{campaignId}": {
      "schema": "CrmCampaign",
      "description": "Repositório de campanhas de e-mail marketing."
    },
    "/settings/brand_knowledge": {
      "schema": "BrandKnowledge",
      "description": "Configuração única da identidade da marca."
    },
    "/settings/ai_config": {
      "schema": "object",
      "description": "Configurações de modelos e prompts globais."
    },
    "/cityPages/{cityId}": {
      "schema": "CityPage",
      "description": "Armazenamento de capas e metadados de cidades."
    },
    "/recurring_occurrences/{occId}": {
      "schema": "RecurringOccurrence",
      "description": "Instâncias individuais de eventos com agenda."
    }
  }
}
