
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado deterministicamente" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "website": { "type": "string" },
        "showEmail": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "PasswordReset": {
      "title": "Redefinição de Senha",
      "description": "Tokens temporários para troca de senha via código",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "used": { "type": "boolean" }
      }
    },
    "Organization": {
      "title": "Organização",
      "description": "Entidade promotora de eventos (Produtora, ONG, etc)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "banner": { "type": "string" },
        "type": { "type": "string" },
        "verified": { "type": "boolean" },
        "stripeAccountId": { "type": "string" },
        "payoutSettings": { "type": "object" },
        "adBalance": { "type": "number", "description": "Saldo disponível para campanhas de anúncios" },
        "walletBalance": { "type": "number", "description": "Saldo líquido acumulado de vendas" },
        "createdBy": { "type": "string" },
        "phone": { "type": "string" },
        "contactEmail": { "type": "string" },
        "website": { "type": "string" },
        "instagram": { "type": "string" },
        "cnpj": { "type": "string" },
        "legalName": { "type": "string" },
        "cep": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "username", "slug", "type", "createdBy"]
    },
    "OrganizationMember": {
      "title": "Membro da Organização",
      "description": "Permissão de acesso do usuário à organização",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "editor", "finance", "checkin"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "status"]
    },
    "Event": {
      "title": "Evento",
      "description": "Evento vinculado a uma organização",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "banner": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "visibility": { "type": "string", "enum": ["public", "private", "unlisted"] },
        "status": { "type": "string", "enum": ["draft", "published", "cancelled", "finished"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "title", "slug", "startDate", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Identidade pessoal e configurações"
    },
    "/password_resets/{resetId}": {
      "schema": "PasswordReset",
      "description": "Controle de tokens de recuperação"
    },
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Entidades promotoras"
    },
    "/organizations/{orgId}/members/{userId}": {
      "schema": "OrganizationMember",
      "description": "RBAC da organização"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Eventos de organizações"
    }
  }
}
