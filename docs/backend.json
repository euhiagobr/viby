
{
  "entities": {
    "Organizer": {
      "title": "Organizador",
      "description": "Informações do promotor do evento",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string", "description": "Nome de usuário único, min 5 chars, alfanumérico" },
        "avatar": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "followersCount": { "type": "number" },
        "rating": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "totalEvents": { "type": "number" },
        "platform": { "type": "string", "enum": ["viby"] },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["name", "email", "username", "platform"]
    },
    "Username": {
      "title": "Unicidade de Usuário",
      "description": "Mapeamento para garantir nomes de usuário únicos",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Event": {
      "title": "Evento",
      "description": "Informações do evento para divulgação",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string", "enum": ["Público", "Privado", "Governo"] },
        "status": { "type": "string", "enum": ["A fazer", "Em progresso", "Concluído"] },
        "image": { "type": "string" },
        "organizerId": { "type": "string" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isFree": { "type": "boolean" },
        "organizer": { "$ref": "#/backend/entities/Organizer" }
      },
      "required": ["title", "date", "location", "organizerId"]
    },
    "Registration": {
      "title": "Participação",
      "description": "Registro de interesse de um usuário em um evento",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "userId"]
    },
    "Category": {
      "title": "Categoria",
      "description": "Categorias de classificação para eventos",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "slug"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Coleção global de eventos Viby"
    },
    "/users/{userId}": {
      "schema": "Organizer",
      "description": "Perfis dos organizadores Viby"
    },
    "/usernames/{username}": {
      "schema": "Username",
      "description": "Índice de nomes de usuário para garantir unicidade"
    },
    "/registrations/{regId}": {
      "schema": "Registration",
      "description": "Interesses registrados nos eventos Viby"
    },
    "/categories/{catId}": {
      "schema": "Category",
      "description": "Categorias de eventos gerenciadas por admins"
    }
  }
}
