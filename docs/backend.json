
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado deterministicamente" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "website": { "type": "string" },
        "showEmail": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "Event": {
      "title": "Evento",
      "description": "Dados principais de um evento",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "possuiMapa": { "type": "boolean" },
        "palcoNome": { "type": "string" },
        "palcoPosX": { "type": "number" },
        "palcoPosY": { "type": "number" },
        "palcoWidth": { "type": "number" },
        "palcoHeight": { "type": "number" },
        "mapaConfigurado": { "type": "boolean" },
        "organizationId": { "type": "string" },
        "capacidadeTotal": { "type": "number", "description": "Capacidade máxima do evento" },
        "loteAtual": { "type": "number", "description": "Índice do lote ativo" },
        "batches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "startDate": { "type": "string", "format": "date-time" },
              "endDate": { "type": "string", "format": "date-time" },
              "capacidadeInicial": { "type": "number", "description": "Carga inicial de venda deste lote" },
              "capacidadeAtual": { "type": "number", "description": "Carga inicial + sobras de lotes anteriores" },
              "vendidos": { "type": "number" },
              "restantes": { "type": "number" },
              "migradosDoLoteAnterior": { "type": "number" }
            }
          }
        }
      }
    },
    "Sector": {
      "title": "Setor do Mapa",
      "description": "Configuração de um setor no mapa de ingressos",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "tipo": { "type": "string", "enum": ["livre", "assentos", "mesas"] },
        "preco": { "type": "number" },
        "capacidadeTotal": { "type": "number" },
        "cor": { "type": "string" },
        "posX": { "type": "number" },
        "posY": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "zIndex": { "type": "number" },
        "formatoVisual": { "type": "string", "enum": ["retangulo", "circulo", "arena", "arredondado"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Identidade pessoal e configurações"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Publicações de eventos"
    },
    "/events/{eventId}/setores/{sectorId}": {
      "schema": "Sector",
      "description": "Setores do mapa de um evento"
    },
    "/events/{eventId}/setores/{sectorId}/assentos/{seatId}": {
      "schema": "Seat",
      "description": "Lugares individuais de um setor"
    }
  }
}
