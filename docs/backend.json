{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "InternalExpense": {
      "title": "Despesa Interna",
      "description": "Registro de saída financeira da plataforma",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "proofUrl": { "type": "string" }
      }
    },
    "PayoutRequest": {
      "title": "Solicitação de Repasse",
      "description": "Pedido de saque de um organizador",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pendente", "Concluído", "Bloqueado"] },
        "bankDetails": { "type": "object" }
      }
    },
    "TaxTicket": {
      "title": "Lançamento Fiscal de Ingresso",
      "description": "Registro detalhado de impostos e taxas por venda",
      "type": "object",
      "properties": {
        "eventTitle": { "type": "string" },
        "totalFacePrice": { "type": "number" },
        "vibyNetProfit": { "type": "number" },
        "taxAmount": { "type": "number" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários"
    },
    "/internal_expenses/{expenseId}": {
      "schema": "InternalExpense",
      "description": "Despesas operacionais da Viby"
    },
    "/payout_requests/{payoutId}": {
      "schema": "PayoutRequest",
      "description": "Gestão de saques dos produtores"
    },
    "/tax_tickets/{taxId}": {
      "schema": "TaxTicket",
      "description": "Livro fiscal de ingressos"
    },
    "/tax_ads/{adTaxId}": {
      "schema": "TaxAd",
      "description": "Livro fiscal de anúncios"
    }
  }
}