
{
  "entities": {
    "Organizer": {
      "title": "Organizador",
      "description": "Informações do promotor do evento",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "email": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "totalEvents": { "type": "number" }
      },
      "required": ["name", "email"]
    },
    "Event": {
      "title": "Evento",
      "description": "Informações do evento para divulgação",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string", "enum": ["Público", "Privado", "Governo"] },
        "status": { "type": "string", "enum": ["A fazer", "Em progresso", "Concluído"] },
        "image": { "type": "string" },
        "organizer": { "$ref": "#/backend/entities/Organizer" }
      },
      "required": ["title", "date", "location"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Coleção global de eventos para divulgação"
    },
    "/users/{userId}": {
      "schema": "Organizer",
      "description": "Perfis dos organizadores cadastrados"
    }
  }
}
