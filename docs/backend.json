
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado deterministicamente" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "website": { "type": "string" },
        "showEmail": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "Event": {
      "title": "Evento",
      "description": "Dados principais de um evento",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "possuiMapa": { "type": "boolean" },
        "palcoNome": { "type": "string" },
        "organizationId": { "type": "string" }
      }
    },
    "Sector": {
      "title": "Setor do Mapa",
      "description": "Configuração de um setor no mapa de ingressos",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "tipo": { "type": "string", "enum": ["livre", "assentos", "mesas"] },
        "preco": { "type": "number" },
        "capacidade": { "type": "number" },
        "cor": { "type": "string" },
        "fileiras": { "type": "number" },
        "assentosPorFileira": { "type": "number" },
        "quantidadeMesas": { "type": "number" },
        "lugaresPorMesa": { "type": "number" },
        "formatoMesa": { "type": "string", "enum": ["circular", "quadrada"] }
      }
    },
    "Seat": {
      "title": "Assento/Lugar",
      "description": "Unidade individual de lugar marcado",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "status": { "type": "string", "enum": ["disponivel", "reservado", "vendido", "bloqueado"] },
        "reservadoPor": { "type": "string" },
        "reservadoAte": { "type": "string", "format": "date-time" }
      }
    },
    "UserGamification": {
      "title": "Gamificação do Usuário",
      "description": "Dados de progresso, XP e nível",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currentXp": { "type": "number", "default": 0 },
        "totalXp": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "levelName": { "type": "string" },
        "nextLevelXp": { "type": "number" },
        "lastActivityAt": { "type": "string", "format": "date-time" }
      }
    },
    "CulturalStats": {
      "title": "Estatísticas Culturais",
      "description": "Perfil de consumo cultural do usuário",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topCategory": { "type": "string" },
        "topNeighborhood": { "type": "string" },
        "topCity": { "type": "string" },
        "totalEvents": { "type": "number" },
        "totalCheckins": { "type": "number" },
        "categoriesExplored": { "type": "array", "items": { "type": "string" } },
        "neighborhoodsExplored": { "type": "array", "items": { "type": "string" } },
        "citiesExplored": { "type": "array", "items": { "type": "string" } },
        "favoriteOrganizers": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Identidade pessoal e configurações"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Publicações de eventos"
    },
    "/events/{eventId}/setores/{sectorId}": {
      "schema": "Sector",
      "description": "Setores do mapa de um evento"
    },
    "/events/{eventId}/setores/{sectorId}/assentos/{seatId}": {
      "schema": "Seat",
      "description": "Lugares individuais de um setor"
    },
    "/user_gamification/{userId}": {
      "schema": "UserGamification",
      "description": "Progresso de gamificação por usuário"
    },
    "/cultural_stats/{userId}": {
      "schema": "CulturalStats",
      "description": "Perfil cultural e estatísticas por usuário"
    },
    "/levels/{levelId}": {
      "schema": "object",
      "description": "Configuração dos níveis de progressão"
    },
    "/badges/{badgeId}": {
      "schema": "object",
      "description": "Configuração de medalhas e conquistas"
    },
    "/user_badges/{userBadgeId}": {
      "schema": "object",
      "description": "Associação entre usuários e medalhas conquistadas"
    },
    "/xp_rules/{ruleId}": {
      "schema": "object",
      "description": "Regras automáticas de ganho de XP"
    },
    "/xp_logs/{logId}": {
      "schema": "object",
      "description": "Histórico detalhado de ganhos de XP"
    },
    "/tax_ads/{taxId}": {
      "schema": "object",
      "description": "Registros de impostos de anúncios"
    },
    "/tax_tickets/{taxId}": {
      "schema": "object",
      "description": "Registros de impostos de ingressos"
    },
    "/payout_requests/{requestId}": {
      "schema": "object",
      "description": "Solicitações de saque das organizações"
    }
  }
}
