{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado deterministicamente" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "website": { "type": "string" },
        "showEmail": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "TaxAd": {
      "title": "Imposto sobre Anúncio",
      "description": "Registro consolidado de imposto para campanhas publicitárias",
      "type": "object",
      "properties": {
        "adId": { "type": "string" },
        "advertiserCnpj": { "type": "string" },
        "advertiserName": { "type": "string" },
        "adTitle": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ativo", "finalizado", "cancelado"] },
        "grossValue": { "type": "number" },
        "taxPercent": { "type": "number" },
        "taxValue": { "type": "number" },
        "netValue": { "type": "number" },
        "nfDeadlineDate": { "type": "string", "format": "date" },
        "nfStatus": { "type": "string", "enum": ["pendente", "emitida"] },
        "monthKey": { "type": "string", "description": "YYYY-MM" }
      }
    },
    "TaxTicket": {
      "title": "Imposto sobre Ingressos",
      "description": "Registro consolidado de imposto sobre taxas e comissões da Viby",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "organizationId": { "type": "string" },
        "orgName": { "type": "string" },
        "orgCnpj": { "type": "string" },
        "ticketsSold": { "type": "number" },
        "vibyGrossValue": { "type": "number" },
        "taxPercent": { "type": "number" },
        "taxValue": { "type": "number" },
        "vibyNetValue": { "type": "number" },
        "nfDeadlineDate": { "type": "string", "format": "date" },
        "nfStatus": { "type": "string", "enum": ["pendente", "emitida"] },
        "monthKey": { "type": "string", "description": "YYYY-MM" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Identidade pessoal e configurações"
    },
    "/tax_ads/{taxId}": {
      "schema": "TaxAd",
      "description": "Registros de impostos de anúncios"
    },
    "/tax_tickets/{taxId}": {
      "schema": "TaxTicket",
      "description": "Registros de impostos de ingressos"
    },
    "/tax_audit/{auditId}": {
      "schema": "object",
      "description": "Histórico de auditoria de impostos"
    },
    "/tax_exports/{exportId}": {
      "schema": "object",
      "description": "Histórico de exportações de dados fiscais"
    }
  }
}
