
{
  "entities": {
    "User": {
      "title": "Usuário",
      "description": "Perfil pessoal e identidade de acesso",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "cpf": { "type": "string", "description": "Criptografado" },
        "gender": { "type": "string", "enum": ["masculino", "feminino", "homem trans", "mulher trans", "agênero", "outro"] },
        "birthDate": { "type": "string", "format": "date" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "top"] },
        "walletBalance": { "type": "number", "description": "Saldo em reais disponível para uso na plataforma" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "plan"]
    },
    "WalletTransaction": {
      "title": "Transação de Carteira",
      "description": "Registro de crédito ou débito na carteira do usuário",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "reason": { "type": "string", "description": "Motivo (ex: estorno_ingresso, compra_ingresso)" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notificação",
      "description": "Alertas de sistema, menções e interações sociais",
      "type": "object",
      "properties": {
        "targetUid": { "type": "string", "description": "UID do destinatário" },
        "senderId": { "type": "string", "description": "UID do remetente" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["mention", "follow", "system"] },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "InternalExpense": {
      "title": "Despesa Interna",
      "description": "Registro de saída financeira da plataforma",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "proofUrl": { "type": "string" }
      }
    },
    "PayoutRequest": {
      "title": "Solicitação de Repasse",
      "description": "Pedido de saque de um organizador",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pendente", "Concluído", "Bloqueado"] },
        "bankDetails": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários"
    },
    "/wallet_transactions/{txId}": {
      "schema": "WalletTransaction",
      "description": "Extrato de créditos e débitos dos usuários"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Central de notificações e menções"
    }
  }
}
