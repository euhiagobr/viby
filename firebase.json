
{
  "firestore": [
    {
      "database": "(default)",
      "rules": "firestore.rules"
    },
    {
      "database": "eventosviby",
      "rules": "firestore.eventosviby.rules"
    }
  ],
  "hosting": [
    {
      "target": "ong",
      "public": "apps/ong/out",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "viby",
      "public": "out",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "storage": [
    {
      "bucket": "ong-desafios-3942a.firebasestorage.app",
      "rules": "storage.rules"
    },
    {
      "bucket": "viby",
      "rules": "storage.viby.rules"
    }
  ]
}
