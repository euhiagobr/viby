{
  "version": "1.0",
  "description": "City Guide Page - Schema documentation for Firestore collections used in /o-que-fazer-em/[pais-estado]/[cidade]",
  "collections": {
    "events": {
      "path": "events",
      "description": "Events collection used for city guide page",
      "requiredFields": {
        "id": "string (auto-generated by Firestore)",
        "title": "string",
        "city": "string (lowercase slug, e.g., 'porto-alegre')",
        "image": "string (URL or Firebase Storage path)",
        "location": "string",
        "category": "string (e.g., 'evento')",
        "status": "string (e.g., 'published')",
        "price": "number (optional)",
        "isFree": "boolean (optional)",
        "rating": "number (optional, 0-5)",
        "reviewCount": "number (optional)"
      },
      "queryPattern": "db.collection('events').where('city', '==', citySlug).where('status', '==', 'published').limit(50)"
    },
    "experiences": {
      "path": "experiences",
      "description": "Experiences collection used for city guide page",
      "requiredFields": {
        "id": "string (auto-generated)",
        "title": "string",
        "city": "string (lowercase slug)",
        "image": "string",
        "location": "string",
        "category": "string (e.g., 'experiência')",
        "status": "string",
        "price": "number (optional)",
        "isFree": "boolean (optional)",
        "rating": "number (optional)",
        "reviewCount": "number (optional)"
      },
      "queryPattern": "db.collection('experiences').where('city', '==', citySlug).where('status', '==', 'published').limit(50)"
    },
    "restaurants": {
      "path": "restaurants",
      "description": "Restaurants collection",
      "requiredFields": {
        "id": "string",
        "title": "string",
        "city": "string (lowercase slug)",
        "image": "string",
        "location": "string",
        "type": "string (e.g., 'restaurante')",
        "status": "string",
        "price": "number (optional)",
        "rating": "number (optional)",
        "reviewCount": "number (optional)"
      },
      "queryPattern": "db.collection('restaurants').where('city', '==', citySlug).where('status', '==', 'published').limit(50)"
    },
    "bars": {
      "path": "bars",
      "description": "Bars collection",
      "requiredFields": {
        "id": "string",
        "title": "string",
        "city": "string (lowercase slug)",
        "image": "string",
        "location": "string",
        "type": "string (e.g., 'bar')",
        "status": "string",
        "price": "number (optional)",
        "rating": "number (optional)",
        "reviewCount": "number (optional)"
      },
      "queryPattern": "db.collection('bars').where('city', '==', citySlug).where('status', '==', 'published').limit(50)"
    },
    "cafes": {
      "path": "cafes",
      "description": "Cafes collection",
      "requiredFields": {
        "id": "string",
        "title": "string",
        "city": "string (lowercase slug)",
        "image": "string",
        "location": "string",
        "type": "string (e.g., 'café')",
        "status": "string",
        "price": "number (optional)",
        "rating": "number (optional)",
        "reviewCount": "number (optional)"
      },
      "queryPattern": "db.collection('cafes').where('city', '==', citySlug).where('status', '==', 'published').limit(50)"
    }
  },
  "requiredIndexes": [
    {
      "collection": "events",
      "fields": [
        { "fieldPath": "city", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collection": "experiences",
      "fields": [
        { "fieldPath": "city", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collection": "restaurants",
      "fields": [
        { "fieldPath": "city", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collection": "bars",
      "fields": [
        { "fieldPath": "city", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collection": "cafes",
      "fields": [
        { "fieldPath": "city", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    }
  ]
}
