{
  "collection": "password_reset_codes",
  "description": "Armazenamento de códigos OTP para recuperação de senha",
  "fields": {
    "userId": "string (UID do usuário)",
    "email": "string (E-mail para conferência)",
    "code": "string (6 dígitos numéricos)",
    "createdAt": "timestamp (servidor)",
    "expiresAt": "timestamp (+15 minutos)",
    "used": "boolean (flag de uso único)",
    "usedAt": "timestamp (registro de consumo)",
    "attempts": "number (máx 10 tentativas de validação)"
  },
  "security_rules": "Permitir create se deslogado. Permitir read/update apenas se souber o ID do documento (validação cega)."
}
