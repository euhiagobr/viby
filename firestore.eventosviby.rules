rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funções de utilidade
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isVibyUser() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.platform == "viby";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Regras para Coleção de Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isVibyUser();
      allow update, delete: if isVibyUser() && resource.data.organizerId == request.auth.uid;
    }

    // Regras para Coleção de Usuários/Organizadores
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.platform == "viby";
      allow update, delete: if isOwner(userId) && isVibyUser();
    }

    // Regras para Unicidade de Nome de Usuário
    match /usernames/{username} {
      // Aberto para leitura pública para permitir verificação de disponibilidade em tempo real
      allow read: if true;
      // Permite criar se estiver autenticado e o nome não existir
      allow create: if isAuthenticated() && !exists(/databases/$(database)/documents/usernames/$(username));
      // Permite deletar se for o dono
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Regras para Coleção de Participações/Inscrições
    match /registrations/{regId} {
      allow create: if isVibyUser();
      allow read: if isVibyUser() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
      );
    }
  }
}
