rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEPLOY VIBY - Versão: 1.0.6
    // REGRAS PARA A PLATAFORMA VIBY CLUB

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Regras padrão: permitir leitura pública, escrita apenas autenticado
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Denúncias: Apenas admins podem listar/ler detalhes
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Categorias: Apenas admins podem gerenciar
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários: Dono ou Admin podem escrever
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}