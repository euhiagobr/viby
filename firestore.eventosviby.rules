
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // --- FUNÇÕES DE APOIO ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS PÚBLICAS (Navegação sem login) ---

    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn(); 

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin());
        allow write: if isSignedIn();
      }
      
      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if isSignedIn();
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /viewers/{userId} {
        allow read, write: if isSignedIn();
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.followerId || request.auth.uid == resource.data.followerId);
    }

    // --- REGRAS PRIVADAS (Usuários e Transações) ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
    }

    match /registrations/{regId} {
      // Permite listagem para contar interessados, mas protege dados sensíveis no get se necessário
      allow read: if true; 
      allow create, update: if isSignedIn();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /user_badges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /badges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- SISTEMA E ADMIN ---

    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; 
      allow update: if isAdmin();
    }

    match /sent_emails/{docId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /tax_tickets/{docId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /tax_ads/{docId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /internal_expenses/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // --- COLLECTION GROUPS ---
    match /{path=**}/members/{memberId} {
      allow read, list: if isSignedIn();
    }

    match /{path=**}/partners/{partnerId} {
      allow read, list: if true;
    }

    // Padrão de segurança para o resto
    match /{allPaths=**} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
