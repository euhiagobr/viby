rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // VIBY PLATFORM RULES - Versão: 1.3.0
    // Banco de Dados: eventosviby

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Verificação robusta de administrador no banco eventosviby
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Configurações do Site: Leitura pública total para branding, escrita apenas Admin
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários: Leitura pública, escrita para o próprio ou Admin
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Unicidade de nomes de usuário
    match /usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Eventos: Leitura pública, escrita para organizadores ou Admin
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
    }
    
    // Inscrições em eventos
    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Denúncias
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Categorias
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra padrão de segurança
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}