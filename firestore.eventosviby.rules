
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- APOIO A COLLECTION GROUP QUERIES (FUNDAMENTAL PARA O DASHBOARD) ---
    match /{path=**}/members/{memberId} {
      // Permite que o usuário liste em quais orgs ele é membro para montar o contexto
      allow read, list: if isSignedIn() && (request.auth.uid == memberId || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /{path=**}/partners/{partnerId} {
      // Leitura pública de parcerias para exibição nos eventos
      allow read, list: if true;
      allow write: if isSignedIn();
    }

    // --- REGRAS POR COLEÇÃO ---

    // Configurações Globais (Públicas)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Perfis de Usuários (Público com proteção de dados sensíveis)
    match /users/{userId} {
      allow read, get: if true;
      allow list: if true; // Permite busca de perfis por username
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'followingCount', 'updatedAt', 'totalXp', 'level', 'walletBalance']));

      match /private/sensitive {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Eventos (Públicos)
    match /events/{eventId} {
      allow read, get, list: if true; // Aberto para navegação anônima
      allow create: if isSignedIn();
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'interestedCount', 'goingCount', 'sharesCount']));
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /partners/{partnerId} {
        allow read, list: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /interests/{userId} {
        allow read, list: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /setores/{setorId} {
        allow read, list: if true;
        allow write: if isSignedIn();
        match /assentos/{assentoId} {
          allow read, list: if true;
          allow write: if isSignedIn();
        }
      }
    }

    // Organizações (Públicas)
    match /organizations/{orgId} {
      allow read, get, list: if true; // Aberto para navegação anônima
      allow create: if isSignedIn();
      allow update: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt', 'totalViews', 'totalReach', 'adBalance', 'blockedBalance']));

      match /members/{userId} {
        allow read, list: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin());
        allow update: if (isSignedIn() && request.auth.uid == userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
        allow create, delete: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
      }

      match /transactions/{txId} {
        allow read, list: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if isSignedIn();
      }
    }

    // Ingressos e Registros (Privados)
    match /registrations/{regId} {
      allow read, get: if resource.data.checkedIn == true || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid ||
        hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance']) || 
        isAdmin()
      ));
      allow list: if isSignedIn(); // Permite que o usuário liste seus próprios ingressos (filtrado por query)
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin();
    }

    // Pedidos (Orders)
    match /orders/{orderId} {
      allow read, get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Notificações (Privadas ao destinatário)
    match /notifications/{notifId} {
      allow read, get, list: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    // Anúncios (Públicos)
    match /ads/{adId} {
      allow read, get, list: if true;
      allow write: if isSignedIn() || isAdmin();
      
      match /viewers/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Categorias e Usernames (Públicos)
    match /categories/{catId} {
      allow read, get, list: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Seguidores
    match /follows/{followId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // Suporte (Tickets)
    match /support_tickets/{ticketId} {
      allow read, get, list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Gamificação (Público se não oculto pelo usuário)
    match /user_gamification/{userId} {
      allow read, get: if true;
      allow list: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /xp_logs/{logId} {
      allow read, list: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    // Padrão de segurança para o resto
    match /{allPaths=**} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
