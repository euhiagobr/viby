rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEPLOY VIBY - Versão: 1.0.1
    // REGRAS PÚBLICAS TOTAIS PARA A PLATAFORMA VIBY
    // Permite leitura e escrita para qualquer pessoa em todos os documentos deste banco (eventosviby).
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}