
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // REGRAS VIBY - Versão: 2.19.0
    // Ajustado para permitir gamificação via Admin e correção de travas de leitura
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/eventosviby/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        (get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' || 
         !('status' in get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        (get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' ||
         !('status' in get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data));
    }

    // Regras globais para buscas via collectionGroup
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    match /{path=**}/partners/{partnerId} {
      allow read: if true;
    }

    // Configurações do Site
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários e Perfis
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Gamificação e Estatísticas (Adicionada permissão Admin para motor de XP)
    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /cultural_stats/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /xp_logs/{logId} {
      // Permitir leitura por qualquer usuário logado para check de idempotência do motor de XP
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    match /user_badges/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Configurações de Gamificação (Leitura pública para o motor de XP)
    match /levels/{levelId} { allow read: if true; }
    match /badges/{badgeId} { allow read: if true; }
    match /xp_rules/{ruleId} { allow read: if true; }

    // Unicidade de Nomes de Usuário
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if (isSignedIn() && get(/databases/eventosviby/documents/usernames/$(username)).data.uid == request.auth.uid) || isAdmin();
    }

    // Redefinição de Senha (Tokens temporários)
    match /password_resets/{resetId} {
      allow read, create, update: if true; 
    }

    // Organizações
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(orgId, ['owner', 'admin', 'editor']) || isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalViews', 'metrics_views_current', 'totalReach', 'metrics_reach_current', 'adBalance', 'blockedBalance'])
      );
      allow delete: if hasOrgRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isOrgMember(orgId) || isAdmin());
        allow update: if (isSignedIn() && request.auth.uid == userId && request.resource.data.status == 'accepted') || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
        allow create, delete: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
      }

      match /visitors/{visitorId} {
        allow read: if isOrgMember(orgId) || isAdmin();
        allow create, update: if isSignedIn();
      }

      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']);
        allow create: if hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance']);
      }
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'editor']);
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow update: if hasOrgRole(partnerId, ['owner', 'admin', 'editor']) || hasOrgRole(get(/databases/eventosviby/documents/events/$(eventId)).data.organizationId, ['owner', 'admin', 'editor']);
        allow create, delete: if hasOrgRole(get(/databases/eventosviby/documents/events/$(eventId)).data.organizationId, ['owner', 'admin', 'editor']);
      }
    }
    
    // Anúncios
    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn() && hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'editor']); 
      allow update: if isSignedIn() || isAdmin(); 
      allow delete: if isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin']);

      match /viewers/{userId} {
        allow read, create: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid ||
        hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /sent_emails/{emailId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if true; 
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']);
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // Solicitações de Saque
    match /payout_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin());
      allow create: if isSignedIn() && hasOrgRole(request.resource.data.organizationId, ['owner', 'admin']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Fiscal e Impostos (Admin Only)
    match /tax_ads/{taxId} {
      allow read, write: if isAdmin();
    }
    match /tax_tickets/{taxId} {
      allow read, write: if isAdmin();
    }
    match /tax_audit/{auditId} {
      allow read, write: if isAdmin();
    }
    match /tax_exports/{exportId} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
