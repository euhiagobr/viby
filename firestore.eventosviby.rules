rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funções de utilidade
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Busca dados do usuário logado
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isVibyUser() {
      return isAuthenticated() && getUserData().platform == "viby";
    }

    function isAdmin() {
      return isVibyUser() && getUserData().role == "admin";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // REGRAS DE LEITURA PÚBLICA (CONFORME SOLICITADO)
    // Todos os dados podem ser lidos por qualquer pessoa.
    // As permissões de escrita permanecem restritas aos donos/admin.

    match /events/{eventId} {
      allow read: if true;
      allow create: if isVibyUser();
      allow update, delete: if isVibyUser() && resource.data.organizerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.platform == "viby";
      allow update, delete: if isOwner(userId) && isVibyUser();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /registrations/{regId} {
      allow read: if true;
      allow create: if isVibyUser();
      allow delete: if isVibyUser() && resource.data.userId == request.auth.uid;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}