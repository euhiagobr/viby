rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGRAS PÚBLICAS TOTAIS (CONFORME SOLICITADO)
    // Permite leitura e escrita para qualquer pessoa em todos os documentos deste banco.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}