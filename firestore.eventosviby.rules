
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // --- FUNÇÕES DE APOIO ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isNotBlocked(data) {
      return !data.keys().contains('status') || data.status != 'Bloqueado';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE LOGS (ErrorManager) ---
    match /system_logs/{logId} {
      allow create: if true; // Permite que qualquer erro seja registrado
      allow read, list, update, delete: if isAdmin();
    }

    // --- REGRAS PÚBLICAS (Navegação sem login) ---

    match /events/{eventId} {
      allow read: if isNotBlocked(resource.data);
      allow write: if isSignedIn() && isNotBlocked(get(/databases/eventosviby/documents/users/$(request.auth.uid)).data); 

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked(get(/databases/eventosviby/documents/users/$(request.auth.uid)).data);
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /organizations/{orgId} {
      allow read: if isNotBlocked(resource.data) || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin();
      allow write: if isSignedIn() && isNotBlocked(get(/databases/eventosviby/documents/users/$(request.auth.uid)).data);

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin());
        allow write: if isSignedIn();
      }
      
      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if isSignedIn();
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /viewers/{userId} {
        allow read, write: if isSignedIn();
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.followerId || request.auth.uid == resource.data.followerId);
    }

    // --- REGRAS PRIVADAS (Usuários e Transações) ---

    match /users/{userId} {
      allow read: if (isNotBlocked(resource.data)) || isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if true; 
      allow create, update: if isSignedIn() && isNotBlocked(get(/databases/eventosviby/documents/users/$(request.auth.uid)).data);
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Padrão de segurança para o resto
    match /{allPaths=**} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
