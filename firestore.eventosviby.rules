
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // REGRAS VIBY - Versão: 4.0.0 (AUDITORIA DE SEGURANÇA E ACESSO PÚBLICO)
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/eventosviby/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        (get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' || 
         !('status' in get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        (get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' ||
         !('status' in get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data));
    }

    // --- COLEÇÕES PÚBLICAS (Descoberta e Configurações) ---
    
    match /events/{eventId} {
      allow read: if true;
      allow create: if hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'editor']);
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if hasOrgRole(get(/databases/eventosviby/documents/events/$(eventId)).data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /setores/{sectorId} {
        allow read: if true;
        allow write: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
        
        match /assentos/{seatId} {
          allow read: if true;
          allow write: if isSignedIn();
        }
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOrgMember(orgId) || isAdmin();
      allow delete: if hasOrgRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        allow read: if true; // Membros são públicos para exibição no dashboard/perfil
        allow update: if (isSignedIn() && request.auth.uid == userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
        allow create, delete: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
      }

      match /visitors/{visitorId} {
        allow read: if isOrgMember(orgId) || isAdmin();
        allow create, update: if true; // Visitantes podem ser registrados anonimamente
      }

      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
      }
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
      
      match /viewers/{viewerId} {
        allow read, write: if true; // Registro de impressões é público
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if (isSignedIn() && get(/databases/eventosviby/documents/usernames/$(username)).data.uid == request.auth.uid) || isAdmin();
    }

    match /levels/{lvlId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_rules/{ruleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- USUÁRIOS ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- REGISTROS E INGRESSOS (Protegidos) ---
    match /registrations/{regId} {
      allow read: if true; // Acesso público para validação simplificada, dados sensíveis são omitidos no objeto
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid ||
        hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- SISTEMA E ADMINISTRAÇÃO ---
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /payout_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin());
      allow create: if isSignedIn() && hasOrgRole(request.resource.data.organizationId, ['owner', 'admin']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /internal_expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /tax_ads/{taxId} { allow read: if isAdmin() || true; allow write: if isAdmin(); }
    match /tax_tickets/{taxId} { allow read: if isAdmin() || true; allow write: if isAdmin(); }
    match /tax_audit/{auditId} { allow read, write: if isAdmin(); }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
