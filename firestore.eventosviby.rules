
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isVibyUser() {
      return isAuthenticated() && 
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.platform == "viby";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isVibyUser();
      allow update, delete: if isVibyUser() && resource.data.organizerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.platform == "viby";
      allow update, delete: if isOwner(userId) && isVibyUser();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && !exists(/databases/eventosviby/documents/usernames/$(username));
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /registrations/{regId} {
      allow create: if isVibyUser();
      allow read: if isVibyUser() && (resource.data.userId == request.auth.uid || get(/databases/eventosviby/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid);
    }
  }
}
