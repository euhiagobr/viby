
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOrganizerOfRegistration() {
      return isSignedIn() && (resource.data.organizerId == request.auth.uid);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /settings/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() || isAdmin();
      allow delete: if (isSignedIn() && get(/databases/eventosviby/documents/usernames/$(username)).data.uid == request.auth.uid) || isAdmin();
      allow update: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /events/{eventId} {
      // Regra de leitura: Público lê se não for excluído. Dono e Admin lêem sempre.
      allow read: if (resource.data.status != 'Excluído') || (isSignedIn() && resource.data.organizerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOrganizerOfRegistration() || isAdmin();
      allow delete: if isOrganizerOfRegistration() || isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
