rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // REGRAS VIBY - Versão: 2.8.0
    // Database Exclusivo: eventosviby
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/eventosviby/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        (get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' || 
         get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == null) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        (get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' || 
         get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == null);
    }

    // Regra Crítica para buscas via collectionGroup (Dashboard e Convites)
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId || resource.data.userId == request.auth.uid || isOrgMember(path[3]));
    }

    // Configurações do Site
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários e Perfis
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Unicidade de Nomes de Usuário
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if (isSignedIn() && get(/databases/eventosviby/documents/usernames/$(username)).data.uid == request.auth.uid) || isAdmin();
    }

    // Organizações e Equipe
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(orgId, ['owner', 'admin']);
      allow delete: if hasOrgRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        // Qualquer membro da org pode ver a lista de equipe
        allow read: if isOrgMember(orgId) || request.auth.uid == userId;
        
        // Donos e Admins podem convidar
        allow create: if hasOrgRole(orgId, ['owner', 'admin']);
        
        // O próprio usuário pode recusar (deletar) ou o admin pode remover
        allow delete: if request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin']);
        
        // O próprio usuário pode aceitar seu convite
        allow update: if (request.auth.uid == userId && (resource.data.status == 'pending' || resource.data.status == null)) || 
                      hasOrgRole(orgId, ['owner', 'admin']);
      }
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'editor']);
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
    }
    
    // Anúncios (Ads)
    match /ads/{adId} {
      allow read: if true;
      allow create: if hasOrgRole(request.resource.data.organizationId, ['owner', 'admin']);
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      allow delete: if isAdmin();
    }

    // Registros de Interesse / Ingressos
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.sharedWithUid == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'checkin']));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'checkin']) || isAdmin());
      allow delete: if isAdmin();
    }

    // Logs de E-mail
    match /sent_emails/{emailId} {
      allow read: if isSignedIn();
      allow create: if true; 
    }

    // Cupons de Desconto
    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']);
    }

    // Categorias
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Suporte
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Denúncias e Reports
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Relacionamentos de Seguimento
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // Bloqueio padrão para segurança
    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}