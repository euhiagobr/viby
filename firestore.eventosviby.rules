
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // REGRAS VIBY - Versão: 2.1.0
    // Estas regras aplicam-se exclusivamente ao banco de dados 'eventosviby'
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/eventosviby/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Configurações do Site
    match /settings/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações de Ads (Preços)
    match /settings/ads {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chaves do Stripe
    match /settings/stripe {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    // Configurações de E-mail
    match /settings/email {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    // Usuários e Perfis
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Unicidade de Nomes de Usuário
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if (isSignedIn() && get(/databases/eventosviby/documents/usernames/$(username)).data.uid == request.auth.uid) || isAdmin();
      allow update: if isAdmin();
    }

    // Relacionamentos de Seguimento
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }
    
    // Anúncios (Ads)
    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reach', 'clicks', 'budget', 'updatedAt', 'stats_gender_masculino', 'stats_gender_feminino', 'stats_gender_outros', 'stats_gender_desconhecido', 'stats_age_sub18', 'stats_age_18_24', 'stats_age_25_34', 'stats_age_35_44', 'stats_age_45plus', 'stats_age_desconhecido', 'click_stats_gender_masculino', 'click_stats_gender_feminino', 'click_stats_gender_outros', 'click_stats_gender_desconhecido', 'click_stats_age_sub18', 'click_stats_age_18_24', 'click_stats_age_25_34', 'click_stats_age_35_44', 'click_stats_age_45plus', 'click_stats_age_desconhecido']));
    }

    // Registros de Interesse / Ingressos
    match /registrations/{regId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.organizerId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid || 
        isAdmin()
      );
    }

    // Cupons de Desconto
    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
    }

    // Categorias
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Suporte
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Denúncias e Reports
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Bloqueio padrão
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
