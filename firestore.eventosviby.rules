rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // VIBY PLATFORM RULES - Versão: 1.6.0
    // Banco de Dados: eventosviby

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Configurações do Site (Identidade Visual)
    // Leitura pública para que logo/nome apareçam no login/landing
    match /settings/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Unicidade de nomes de usuário
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
    }
    
    // Inscrições
    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Denúncias
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Categorias
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra padrão de segurança para outras coleções
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}