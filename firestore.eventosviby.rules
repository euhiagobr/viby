rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.organizerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /registrations/{regId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || get(/databases/eventosviby/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid);
    }
  }
}