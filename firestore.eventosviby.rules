
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- COLEÇÕES PÚBLICAS ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Permite atualização se for o dono OU se estiver apenas alterando contadores de follow (necessário para social)
      allow update: if isOwner(userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'followingCount', 'updatedAt', 'totalXp', 'level']));

      match /private/sensitive {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /setores/{setorId} {
        allow read: if true;
        match /assentos/{assentoId} {
          allow read: if true;
          allow write: if isSignedIn();
        }
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Permite atualização se for gestor OU se estiver apenas alterando contador de seguidores
      allow update: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt', 'totalViews', 'totalReach']));

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin());
        allow update: if (isSignedIn() && request.auth.uid == userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
        allow create, delete: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
      }
    }

    match /categories/{catId} {
      allow read: if true;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
      
      match /viewers/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // --- COLEÇÕES PRIVADAS E FINANCEIRAS ---
    match /registrations/{regId} {
      allow read: if resource.data.checkedIn == true || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid ||
        hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance']) || 
        isAdmin()
      ));
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin();
    }

    match /payout_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); 
    }

    match /wallet_transactions/{txId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin(); 
      allow update, delete: if false; 
    }

    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.targetUid) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // --- GAMIFICAÇÃO ---
    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /cultural_stats/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isSignedIn();
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_badges/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /xp_rules/{ruleId} {
      allow read: if true;
    }
    
    match /levels/{levelId} {
      allow read: if true;
    }

    match /password_reset_codes/{docId} {
      allow read, write: if false; 
    }

    // --- COLLECTION GROUPS ---
    match /{path=**}/members/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /{path=**}/partners/{partnerId} {
      allow read: if true;
    }

    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
