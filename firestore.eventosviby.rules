
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // REGRAS VIBY - Versão: 2.3.0
    // Database Exclusivo: eventosviby
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/eventosviby/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getMemberRole(orgId) {
      return get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'accepted' &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // Configurações do Site
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários e Perfis
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Unicidade de Nomes de Usuário
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if (isSignedIn() && get(/databases/eventosviby/documents/usernames/$(username)).data.uid == request.auth.uid) || isAdmin();
    }

    // Organizações e Equipe
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(orgId, ['owner', 'admin']);
      allow delete: if hasOrgRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        // Usuário pode ler seu próprio convite/membro ou se for admin da org
        allow read: if request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin']);
        
        // Donos e Admins podem convidar
        allow create: if hasOrgRole(orgId, ['owner', 'admin']);
        
        // O próprio usuário pode recusar (deletar) ou o admin pode remover
        allow delete: if request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin']);
        
        // O próprio usuário pode aceitar seu convite (mudar status de pending para accepted)
        allow update: if (request.auth.uid == userId && resource.data.status == 'pending' && request.resource.data.status == 'accepted') || 
                      hasOrgRole(orgId, ['owner', 'admin']);
      }
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
    }
    
    // Anúncios (Ads)
    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reach', 'clicks', 'budget', 'updatedAt', 'stats_gender_masculino', 'stats_gender_feminino', 'stats_gender_outros', 'stats_gender_desconhecido', 'stats_age_sub18', 'stats_age_18_24', 'stats_age_25_34', 'stats_age_35_44', 'stats_age_45plus', 'stats_age_desconhecido', 'click_stats_gender_masculino', 'click_stats_gender_feminino', 'click_stats_gender_outros', 'click_stats_gender_desconhecido', 'click_stats_age_sub18', 'click_stats_age_18_24', 'click_stats_age_25_34', 'click_stats_age_35_44', 'click_stats_age_45plus', 'click_stats_age_desconhecido']));
      allow delete: if isAdmin();
    }

    // Registros de Interesse / Ingressos
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.sharedWithUid == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'checkin']));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'checkin']) || isAdmin());
      allow delete: if isAdmin();
    }

    // Logs de E-mail
    match /sent_emails/{emailId} {
      allow read: if isAdmin();
      allow create: if true; 
    }

    // Cupons de Desconto
    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || (request.resource.data.eventId != null && hasOrgRole(get(/databases/eventosviby/documents/events/$(request.resource.data.eventId)).data.organizationId, ['owner', 'admin']));
    }

    // Categorias
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Suporte
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Denúncias e Reports
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Relacionamentos de Seguimento
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // Bloqueio padrão para segurança
    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
