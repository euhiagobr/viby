
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // Configurações Globais
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Perfis de Usuários
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'followingCount', 'updatedAt', 'totalXp', 'level', 'walletBalance']));

      match /private/sensitive {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'interestedCount', 'goingCount', 'sharesCount']));
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /setores/{setorId} {
        allow read: if true;
        allow write: if isSignedIn();
        match /assentos/{assentoId} {
          allow read: if true;
          allow write: if isSignedIn();
        }
      }
    }

    // Organizações
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt', 'totalViews', 'totalReach', 'adBalance', 'blockedBalance']));

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin());
        allow update: if (isSignedIn() && request.auth.uid == userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
        allow create, delete: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
      }

      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if isSignedIn();
      }
    }

    // Ingressos e Registros
    match /registrations/{regId} {
      allow read: if resource.data.checkedIn == true || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid ||
        hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance']) || 
        isAdmin()
      ));
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin();
    }

    // Pedidos (Orders)
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Suporte (Tickets)
    match /support_tickets/{ticketId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Financeiro e Saques
    match /payout_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); 
    }

    match /wallet_transactions/{txId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid); 
      allow update, delete: if false; 
    }

    // Notificações
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.targetUid) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    // Fiscal e Logs de Sistema
    match /tax_tickets/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
    }

    match /tax_ads/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
    }

    match /sent_emails/{docId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /system_logs/{logId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // Gamificação
    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /cultural_stats/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_badges/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /xp_rules/{ruleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /levels/{levelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias e Usernames
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Anúncios
    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
      
      match /viewers/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Seguidores
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /internal_expenses/{docId} {
      allow read, write: if isAdmin();
    }

    // Padrão de segurança
    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
