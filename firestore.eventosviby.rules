rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEPLOY VIBY - Versão: 1.0.8
    // REGRAS PARA A PLATAFORMA VIBY CLUB

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Regras padrão: permitir leitura pública, escrita apenas autenticado
    // Nota: Regras específicas abaixo sobrescrevem comportamentos conforme necessário
    
    // Configurações: Essencial para identidade visual pública
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários: Dono ou Admin podem escrever
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Nomes de usuário: Verificação de unicidade
    match /usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Eventos: Públicos para leitura
    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // Inscrições
    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Denúncias: Apenas admins podem listar/ler detalhes
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Categorias: Apenas admins podem gerenciar
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bloqueio padrão
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}