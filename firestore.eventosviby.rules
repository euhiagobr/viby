rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // VIBY PLATFORM RULES - Versão: 1.2.0
    // Banco de Dados: eventosviby

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Verifica se o documento do usuário existe e se o cargo é admin
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Configurações do Site: Leitura pública para identidade visual, escrita para Admins
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários: Leitura pública, escrita para o próprio usuário ou Admin
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Unicidade de nomes de usuário
    match /usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Eventos: Leitura pública, escrita para usuários autenticados (Empresas) ou Admins
    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.resource.data.organizerId == request.auth.uid || isAdmin());
    }
    
    // Inscrições em eventos
    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Denúncias: Apenas admins leem, usuários autenticados criam
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Categorias: Apenas Admins gerenciam
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regras padrão para outras coleções do banco eventosviby
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}