
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funções de utilidade
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Busca dados do usuário no banco atual (eventosviby)
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isVibyUser() {
      return isAuthenticated() && getUserData().platform == "viby";
    }

    function isAdmin() {
      return isVibyUser() && getUserData().role == "admin";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Regras para Coleção de Eventos: Público para leitura, Privado para escrita
    match /events/{eventId} {
      allow read: if true;
      allow create: if isVibyUser();
      allow update, delete: if isVibyUser() && resource.data.organizerId == request.auth.uid;
    }

    // Regras para Coleção de Usuários/Organizadores
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.platform == "viby";
      allow update, delete: if isOwner(userId) && isVibyUser();
    }

    // Regras para Unicidade de Nome de Usuário: Leitura pública para verificação no cadastro
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Regras para Coleção de Participações/Inscrições
    match /registrations/{regId} {
      allow create: if isVibyUser();
      allow read: if isVibyUser() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
      );
    }

    // Regras para Categorias: Público para leitura, Admin para escrita
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
