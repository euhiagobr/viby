
rules_version = '2';
service cloud.firestore {
  match /databases/eventosviby/documents {
    // REGRAS VIBY - Versão: 4.1.0 (CORREÇÃO DE GESTÃO DE USERNAMES)
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/eventosviby/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && 
        exists(/databases/eventosviby/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- COLEÇÕES PÚBLICAS ---
    
    match /events/{eventId} {
      allow read: if true;
      allow create: if hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'editor']);
      allow update: if hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if hasOrgRole(get(/databases/eventosviby/documents/events/$(eventId)).data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOrgMember(orgId) || isAdmin();
      allow delete: if hasOrgRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        allow read: if true;
        allow update: if (isSignedIn() && request.auth.uid == userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
        allow create, delete: if hasOrgRole(orgId, ['owner', 'admin']) || isAdmin();
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      // Permite deletar se for o dono do perfil ou dono/admin da organização vinculada ao username
      allow delete: if isAdmin() || (
        isSignedIn() && (
          request.auth.uid == resource.data.uid || 
          (resource.data.type == 'organization' && hasOrgRole(resource.data.uid, ['owner', 'admin']))
        )
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /registrations/{regId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sharedWithUid == request.auth.uid ||
        hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
