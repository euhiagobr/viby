rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Configurações Globais - LEITURA PÚBLICA PARA FUNCIONAMENTO DO APP
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias - PÚBLICO PARA FILTROS
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários e Perfis
    match /users/{userId} {
      allow read: if true; // Perfil público
      allow write: if isOwner(userId) || isAdmin();
      
      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Índice de Usernames e Afiliados - PÚBLICO PARA VALIDAÇÃO
    match /usernames/{username} {
      allow read, list: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /affiliateCodes/{code} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // Gamificação e Status Sociais - LEITURA PÚBLICA (Vitrine Cultural)
    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /cultural_stats/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /xp_logs/{logId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /user_badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Organizações e Membros
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if isSignedIn() && (isOwner(resource.data.ownerId) || isAdmin());

      match /members/{userId} {
         allow read: if isSignedIn();
         allow write: if isSignedIn() && (isOwner(userId) || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId);
      }
    }

    // Eventos e Ingressos
    match /events/{eventId} { 
      allow read: if true; 
      allow write: if isSignedIn();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /interests/{interestId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /registrations/{regId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        isAdmin() || 
        get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId == request.auth.uid);
    }

    // Viby Ads
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /viewers/{userId} {
        allow read, write: if isSignedIn();
      }
    }

    // Suporte
    match /support_tickets/{ticketId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Financeiro
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /payout_requests/{reqId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow update: if isAdmin();
    }

    // Logs e Auditoria
    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /sent_emails/{emailId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Regra Geral de Segurança
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}