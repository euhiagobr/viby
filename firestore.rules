rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin(uid) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
    }

    function isMemberOfOrg(uid, orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(uid));
    }

    function isOrganizerOfEvent(uid, eventId) {
      // Busca o organizationId do evento para validar se o usuário é membro daquela org
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return isMemberOfOrg(uid, eventData.organizationId);
    }

    // --- REGRAS POR COLEÇÃO ---

    // Perfis de Usuário
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin(request.auth.uid) || (isSignedIn() && request.auth.uid == userId);
      
      // Subcoleção Sensível (CPF Real)
      match /private/sensitive {
        allow read, write: if isAdmin(request.auth.uid) || (isSignedIn() && request.auth.uid == userId);
      }
    }

    // Organizações e Marcas
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, orgId);

      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, orgId) || (isSignedIn() && memberId == request.auth.uid);
      }

      match /transactions/{txId} {
        allow read: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, orgId);
        allow write: if request.auth == null; // Apenas via Webhook/Server
      }
    }

    // Eventos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin(request.auth.uid) || (isSignedIn() && isMemberOfOrg(request.auth.uid, request.resource.data.organizationId));
      allow update: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, resource.data.organizationId) || (request.auth == null);
      allow delete: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin(request.auth.uid) || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      
      match /setores/{setorId} {
        allow read: if true;
        allow write: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        
        match /assentos/{assentoId} {
          allow read: if true;
          allow write: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, get(/databases/$(database)/documents/events/$(eventId)).data.organizationId) || isSignedIn();
        }
      }
    }

    // Ingressos (Registrations)
    match /registrations/{regId} {
      // Leitura ampla e pública conforme prompt
      allow read: if true;
      
      // Proibir criação via frontend (Somente auth == null via servidor/webhook)
      allow create: if request.auth == null; 
      
      // Permitir update para Check-in ou Estorno (Admin, Organizer ou Server)
      allow update: if isAdmin(request.auth.uid) || 
                    isMemberOfOrg(request.auth.uid, resource.data.organizationId) || 
                    isOrganizerOfEvent(request.auth.uid, resource.data.eventId) ||
                    (request.auth == null);
    }

    // Pedidos (Orders)
    match /orders/{orderId} {
      allow read: if isAdmin(request.auth.uid) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin(request.auth.uid) || (request.auth == null);
    }

    // Ocorrências (Recorrentes)
    match /recurring_occurrences/{occId} {
      allow read: if true;
      allow write: if isAdmin(request.auth.uid) || (isSignedIn() && isMemberOfOrg(request.auth.uid, request.resource.data.organizationId)) || (request.auth == null);
    }

    // Gamificação e Social
    match /user_gamification/{uid} { allow read: if true; allow write: if isAdmin(request.auth.uid) || (request.auth == null); }
    match /xp_logs/{id} { allow read: if isAdmin(request.auth.uid) || (isSignedIn() && resource.data.userId == request.auth.uid); allow write: if isAdmin(request.auth.uid) || (request.auth == null); }
    match /xp_rules/{id} { allow read: if true; allow write: if isAdmin(request.auth.uid); }
    match /levels/{id} { allow read: if true; allow write: if isAdmin(request.auth.uid); }
    match /badges/{id} { allow read: if true; allow write: if isAdmin(request.auth.uid); }
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.followerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.followerId;
    }

    // Configurações e ERP
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(request.auth.uid); }
    match /internal_expenses/{id} { allow read, write: if isAdmin(request.auth.uid); }
    match /tax_tickets/{id} { allow read: if isAdmin(request.auth.uid); allow write: if request.auth == null; }
    match /tax_ads/{id} { allow read: if isAdmin(request.auth.uid); allow write: if request.auth == null; }
    match /system_logs/{id} { allow read: if isAdmin(request.auth.uid); allow create: if true; allow update: if isAdmin(request.auth.uid); }
    match /sent_emails/{id} { allow read: if isAdmin(request.auth.uid); allow create: if request.auth == null; }
    
    // Financeiro e Saques
    match /payout_requests/{id} {
      allow read: if isAdmin(request.auth.uid) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin(request.auth.uid);
    }
    
    // Anúncios
    match /ads/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin(request.auth.uid) || isMemberOfOrg(request.auth.uid, resource.data.organizationId) || (request.auth == null);
      
      match /viewers/{vId} { allow read: if isAdmin(request.auth.uid); allow write: if true; }
    }

    // Suporte e Denúncias
    match /support_tickets/{id} {
      allow read: if isAdmin(request.auth.uid) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin(request.auth.uid) || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /reports/{id} { allow read: if isAdmin(request.auth.uid); allow create: if isSignedIn(); }
    
    // Índices Globais
    match /usernames/{username} { allow read: if true; allow write: if isSignedIn() || (request.auth == null); }
    match /password_reset_codes/{id} { allow read, write: if request.auth == null || isAdmin(request.auth.uid); }

    // --- COLLECTION GROUP RULES ---
    match /{path=**}/members/{memberId} {
      allow read: if isAdmin(request.auth.uid) || (isSignedIn() && memberId == request.auth.uid);
    }
    match /{path=**}/partners/{partnerId} {
      allow read: if true;
    }
  }
}