rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- FUNÇÕES DE HIERARQUIA DE ORGANIZAÇÃO ---

    function getMemberData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isOrgOwner(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        getMemberData(orgId).role == 'owner'
      );
    }

    function isOrgAdmin(orgId) {
      return isSignedIn() && (isOrgOwner(orgId) || getMemberData(orgId).role == 'admin');
    }

    function isOrgEditor(orgId) {
      return isSignedIn() && (isOrgAdmin(orgId) || getMemberData(orgId).role == 'editor');
    }

    function isOrgMember(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- REGRAS POR COLEÇÃO ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      allow update: if isAdmin() || isOrgAdmin(orgId);

      // Impedir alteração de campos críticos via Client SDK por qualquer pessoa que não seja Owner ou Admin Global
      // Campos protegidos: ownerId, verified, status, plan, stripeAccountId
      allow update: if (isAdmin() || isOrgOwner(orgId)) 
                    || (isOrgAdmin(orgId) 
                        && !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['ownerId', 'verified', 'status', 'plan', 'stripeAccountId', 'adBalance', 'blockedBalance']));

      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        
        // Regras de Gestão de Equipe
        // 1. Apenas Owner ou Admin Global podem criar/remover membros gestores (admin/owner)
        // 2. Admins podem gerenciar membros comuns (editor/member)
        allow create, update: if isAdmin() || isOrgOwner(orgId) || (isOrgAdmin(orgId) && request.resource.data.role in ['editor', 'member']);
        
        // 3. Impedir que um membro altere seu próprio cargo (Escalonamento)
        allow update: if request.auth.uid != memberId || isAdmin();
        
        // 4. Impedir que um Admin remova um Owner
        allow delete: if isAdmin() || isOrgOwner(orgId) || (isOrgAdmin(orgId) && resource.data.role != 'owner');
      }

      match /transactions/{txId} {
        allow read: if isAdmin() || isOrgAdmin(orgId);
        allow write: if false; // Exclusivo via Admin SDK (Servidor)
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isOrgEditor(request.resource.data.organizationId);
      allow update, delete: if isAdmin() || isOrgEditor(resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.userId || isOrgMember(resource.data.organizationId)));
      allow create: if false; // Criado apenas via Webhook (Admin SDK)
      allow update: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /ads/{id} {
      allow read: if true;
      allow create: if isAdmin() || isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOrgOwner(resource.data.organizationId);
    }

    match /usernames/{username} { 
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /password_reset_codes/{id} { allow read, write: if false; }
    match /wallets/{uid} { allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin()); allow write: if false; }
    match /wallet_transactions/{id} { allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin()); allow write: if false; }
    match /payout_requests/{id} { allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin()); allow write: if false; }
    match /audit_logs/{id} { allow read: if isAdmin(); allow write: if false; }
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /sent_emails/{id} { allow read: if isAdmin(); allow write: if false; }
  }
}