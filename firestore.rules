rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE APOIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário autenticado é um Administrador Global
    // Esta função é a chave para o acesso ao painel /admin/
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Garante que o usuário não está bloqueado
    // Se o usuário não existir no banco (primeiro acesso) ou não estiver logado, não bloqueamos a leitura pública
    function isNotBlocked() {
      if (!isSignedIn()) return true;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.get('status', 'Ativo') != 'Bloqueado';
    }

    // Verifica cargo em uma organização específica
    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE ACESSO ---

    // 1. REGRA DE OURO: Admin Global tem poder total sobre qualquer documento
    // Esta regra no topo garante que o painel administrativo funcione sem erros de "Insufficient Permissions"
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // 2. Configurações do Sistema
    // Leitura pública para carregar nome do site e logo; escrita apenas para Admin (já coberto acima)
    match /settings/{docId} {
      allow read: if true;
    }

    // 3. Usuários
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId && isNotBlocked() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'adminFlags', 'permissions', 'totalXp', 'level'
        ])) || isAdmin();

      match /private/sensitive {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
    }

    // 4. Organizações
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isAdmin() || (
        isNotBlocked() && (
          (hasOrgRole(orgId, ['owner']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verified', 'status', 'plan', 'ownerId', 'permissions'])) ||
          (hasOrgRole(orgId, ['admin']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'ownerId', 'verified', 'plan', 'stripeAccountId', 
             'payoutSettings', 'financialSettings', 'permissions', 'status'
           ]))
        )
      );

      match /members/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin());
      }
    }

    // 5. Eventos e Ocorrências
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isAdmin() || (isNotBlocked() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor'])));
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn() && (hasOrgRole(resource.data.inviterOrgId, ['owner', 'admin']) || hasOrgRole(partnerId, ['owner', 'admin']) || isAdmin());
      }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /recurring_events/{docId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /recurring_occurrences/{docId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /usernames/{username} { allow read: if true; allow create: if isSignedIn(); }
    
    // 6. Anúncios e Métricas
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && hasOrgRole(resource.data.organizationId, ['owner', 'admin']));
      
      match /viewers/{userId} { 
        allow read: if true; 
        allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin(); 
      }
    }

    // 7. Registros e Transações (Protegidos)
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || (resource.data.keys().contains('organizationId') && hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance'])));
      allow create, delete: if isAdmin(); 
      allow update: if isAdmin() || (isSignedIn() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin'])));
    }

    match /wallets/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow write: if false; 
    }

    match /wallet_transactions/{txId} {
      allow read: if (isSignedIn() && (resource.data.userId == request.auth.uid)) || isAdmin();
      allow write: if false;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update: if isAdmin();
    }

    match /payout_requests/{docId} {
      allow read: if (isSignedIn() && (resource.data.userId == request.auth.uid)) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // 8. Logs e Auditoria
    match /system_logs/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /sent_emails/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /tax_tickets/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /tax_ads/{docId} { allow read, write: if isAdmin(); }
    
    // Tickets de Suporte
    match /support_tickets/{ticketId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'protocol'])) || isAdmin();
    }
  }
}