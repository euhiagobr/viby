
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getAffiliateConfig() {
      return get(/databases/$(database)/documents/settings/affiliates).data;
    }

    function isAffiliateEnabled() {
      let config = getAffiliateConfig();
      return config == null || config.enabled == true;
    }

    // Função central de autorização administrativa
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) ||
        getUserData().role == 'admin'
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        (exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/system_admins/$(request.auth.uid)).data.cargo == 'super_admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE EXCLUSIVIDADE ---
    function isPartner() {
      return getUserData().isPartner == true;
    }

    function isAffiliate() {
      return getUserData().isAffiliate == true;
    }

    // --- REGRAS POR COLEÇÃO ---

    match /settings/affiliates {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /organizer_leads/{leadId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /system_admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || isOwner(userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /affiliateCodes/{code} {
      allow read: if true; 
      // BLOQUEIO: Parceiros não podem criar. Programa deve estar ativo.
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == request.resource.data.userId && !isPartner() && isAffiliateEnabled());
    }

    match /affiliate_stats/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      // BLOQUEIO: Impedir novos registros se for parceiro ou programa desativado
      allow write: if isAdmin() || (isOwner(uid) && !isPartner() && isAffiliateEnabled()); 
    }

    match /affiliate_payouts/{payoutId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /partners/{partnerId} {
      allow read: if isAdmin() || isOwner(partnerId);
      allow write: if isAdmin();
    }

    match /partner_referrals/{refId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.partnerId == request.auth.uid || resource.data.referredUserId == request.auth.uid));
      allow write: if isAdmin();
    }

    match /partner_commissions/{commId} {
       allow read: if isAdmin() || (isSignedIn() && resource.data.partnerId == request.auth.uid);
       allow write: if isAdmin();
    }

    match /partner_withdrawals/{withdrawalId} {
       allow read: if isAdmin() || (isSignedIn() && resource.data.partnerId == request.auth.uid);
       allow write: if isAdmin();
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid));

      match /members/{memberId} {
        allow read: if isAdmin() || isSignedIn();
        allow create, update, delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid);
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)/members/$(request.auth.uid)));
      allow update: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/organizations/$(resource.data.organizationId)/members/$(request.auth.uid)));
      allow delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId == request.auth.uid);

      match /interests/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId == request.auth.uid);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.userId || exists(/databases/$(database)/documents/organizations/$(resource.data.organizationId)/members/$(request.auth.uid))));
      allow create: if isSignedIn(); 
      allow update: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
    }

    match /user_gamification/{uid} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(uid);
    }

    match /support_tickets/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.targetUid == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.targetUid == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
