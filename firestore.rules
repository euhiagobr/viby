
rules_version = '2';
service cloud.firestore {
  match /databases/(default)/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function getRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function hasRole(orgId, roles) {
      return isSignedIn() && getRole(orgId) in roles;
    }

    // Leitura pública global para descoberta
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isUser(userId) || isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasRole(orgId, ['owner', 'admin']) || isAdmin();
      allow delete: if hasRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        allow read: if true;
        allow write: if hasRole(orgId, ['owner', 'admin']) || isAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(request.resource.data.organizationId, ['owner', 'admin', 'editor']);
      allow update: if hasRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
    }
  }
}
