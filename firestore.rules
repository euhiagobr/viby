rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Função central de autorização administrativa
    function isAdmin() {
      return isSignedIn() && (
        // 1. UID Mestre para Bootstrap (Acesso total)
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        // 2. Verificação via Custom Claims
        request.auth.token.admin == true ||
        // 3. Verificação via estrutura granular
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) ||
        // 4. Fallback: Usuário com role 'admin' no perfil principal
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        // 1. UID Mestre para Bootstrap
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        // 2. Verificação granular
        (exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/system_admins/$(request.auth.uid)).data.cargo == 'super_admin') ||
        // 3. Admin Legado
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- HIERARQUIA DE ORGANIZAÇÃO ---

    function getMemberData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isOrgOwner(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        getMemberData(orgId).role == 'owner'
      );
    }

    function isOrgAdmin(orgId) {
      return isSignedIn() && (isOrgOwner(orgId) || getMemberData(orgId).role == 'admin');
    }

    function isOrgEditor(orgId) {
      return isSignedIn() && (isOrgAdmin(orgId) || getMemberData(orgId).role == 'editor');
    }

    function isOrgMember(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- REGRAS POR COLEÇÃO ---

    match /system_admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId)
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt', 'followingCount', 'totalXp', 'level', 'preferredCurrency', 'language']));
      
      match /private/sensitive {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      
      allow update: if (isAdmin() || isOrgOwner(orgId)) 
                    || (isOrgAdmin(orgId) 
                        && !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['ownerId', 'verified', 'status', 'plan', 'stripeAccountId', 'adBalance', 'blockedBalance']))
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt', 'totalAttendeesCount', 'totalViews', 'totalReach']));

      match /members/{memberId} {
        allow read: if isAdmin() 
                    || (isSignedIn() && request.auth.uid == memberId)
                    || (isSignedIn() && isOrgMember(orgId));
        
        allow create: if isSignedIn() && (isAdmin() || request.auth.uid == memberId || isOrgAdmin(orgId));
        allow update: if isAdmin() || isOrgOwner(orgId) || (isOrgAdmin(orgId) && request.resource.data.role in ['editor', 'member', 'finance', 'checkin']);
        allow delete: if isAdmin() || isOrgOwner(orgId) || (isOrgAdmin(orgId) && resource.data.role != 'owner');
      }

      match /transactions/{txId} {
        allow read: if isAdmin() || isOrgAdmin(orgId) || (isSignedIn() && request.auth.uid == resource.data.userId);
        allow write: if false; 
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isOrgEditor(request.resource.data.organizationId);
      allow update, delete: if isAdmin() || isOrgEditor(resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /notifications/{notifId} {
      allow read, list: if isAdmin() || (isSignedIn() && (resource == null || resource.data.targetUid == request.auth.uid || request.query.filters.targetUid == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource == null || resource.data.targetUid == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /qr_scans/{id} {
      allow read: if isAdmin() || isOrgAdmin(resource.data.organizationId);
      allow create: if true;
    }

    match /recurring_events/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOrgAdmin(request.resource.data.organizationId);
    }

    match /recurring_occurrences/{id} {
      allow read: if true;
      allow write: if isAdmin() || isOrgEditor(request.resource.data.organizationId);
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.userId || isOrgMember(resource.data.organizationId)));
      allow create: if isSignedIn(); 
      allow update: if isAdmin() || (isSignedIn() && isOrgEditor(resource.data.organizationId));
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /ads/{id} {
      allow read: if true;
      allow create: if isAdmin() || isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAdmin() || isOrgAdmin(request.resource.data.organizationId);
      allow delete: if isAdmin() || isOrgOwner(request.resource.data.organizationId);
    }

    match /ad_coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin() || isOrgEditor(request.resource.data.organizationId);
    }

    match /usernames/{username} { 
      allow read: if true; 
      allow create: if isAdmin() || (isSignedIn() && (request.resource.data.uid == request.auth.uid || request.resource.data.type == 'organization'));
      allow delete: if isAdmin() || (isSignedIn() && (request.resource.data.uid == request.auth.uid || request.resource.data.type == 'organization'));
      allow update: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tax_tickets/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /tax_ads/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /internal_expenses/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /reports/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /payout_requests/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /support_tickets/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn();
    }

    match /wallets/{uid} { 
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin()); 
      allow write: if false; 
    }
    
    match /wallet_transactions/{id} { 
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin()); 
      allow write: if false; 
    }

    match /levels/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /badges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_rules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_gamification/{uid} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /xp_logs/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == request.resource.data.userId);
    }

    match /cultural_stats/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /follows/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
    }

    match /audit_logs/{id} { 
      allow read: if isAdmin(); 
      allow write: if false; 
    }

    match /system_logs/{id} { 
      allow read: if isAdmin(); 
      allow create: if true; 
    }

    match /sent_emails/{id} { 
      allow read: if isAdmin(); 
      allow write: if false; 
    }

    match /password_reset_codes/{id} { 
      allow read: if false;
      allow write: if false; 
    }

    // --- REGRAS DE GRUPO DE COLEÇÕES (Necessário para queries globais) ---

    match /{path=**}/partners/{partnerId} { 
      allow read: if true; 
    }
    
    match /{path=**}/members/{memberId} { 
      // Permite ler se for o dono do convite/membro (userId) ou se já for membro daquela org específica
      allow read, list: if (isSignedIn() && (request.auth.uid == memberId || resource.data.userId == request.auth.uid))
                        || isOrgMember(path.split('/')[1]); 
    }
    
    match /{path=**}/transactions/{id} { 
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId); 
    }
  }
}