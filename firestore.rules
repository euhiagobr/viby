
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) ||
        getUserData().role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
      );
    }

    // --- REGRAS PÚBLICAS (Acesso sem autenticação para visitantes) ---

    // Configurações Globais (Logo, Branding, SEO)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações de Sistema (Integrações como Google Ads)
    match /system_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Índices de Busca e Categorias
    match /usernames/{username} {
      allow read: if true;
    }

    match /categories/{category} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Páginas de Cidades (SEO)
    match /cityPages/{cityId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Dados de Apoio ao Feed (Recorrências e Anúncios Ativos)
    match /recurring_occurrences/{occId} {
      allow read: if true;
      allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
    }

    // Perfis de Organizações e Eventos Públicos
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(orgId);
    }

    match /events/{eventId} {
      // Eventos 'Ativo' ou 'Oculto' são visíveis. Rascunhos (draft) são privados.
      allow read: if (resource.data.status == 'Ativo') || (resource.data.status == 'Oculto') || isOwner(resource.data.userId) || isOwner(resource.data.organizerId) || isAdmin() || isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isOwner(resource.data.organizerId) || isAdmin() || isOrgMember(resource.data.organizationId);
      allow delete: if isAdmin() || isOwner(resource.data.userId) || isOwner(resource.data.organizerId);

      match /interests/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    // Perfis de Usuários
    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || isOwner(userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // --- REGRAS RESTRITAS (Apenas Admin ou Proprietário) ---
    
    match /registrations/{regId} {
      allow read: if isAdmin() || isOwner(resource.data.userId) || isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(resource.data.organizationId);
    }

    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }

    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Apenas via Server Actions
    }

    // Fallback de segurança para qualquer outra coleção
    match /{path=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
