rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE APOIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica se o usuário autenticado é um Administrador Global
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Garante que o usuário não está bloqueado
    function isNotBlocked() {
      if (!isSignedIn()) return true;
      if (!exists(/databases/$(database)/documents/users/$(request.auth.uid))) return true;
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !userData.keys().contains('status') || userData.status != 'Bloqueado';
    }

    // Verifica cargo em uma organização específica
    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE ACESSO ---

    // Admin Global tem poder total sobre qualquer documento
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // Configurações do Sistema
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && isNotBlocked() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'adminFlags', 'permissions', 'totalXp', 'level'
        ])) || isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Organizações
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isAdmin() || (
        isNotBlocked() && (
          (hasOrgRole(orgId, ['owner']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verified', 'status', 'plan'])) ||
          (hasOrgRole(orgId, ['admin']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'ownerId', 'verified', 'plan', 'stripeAccountId', 
             'payoutSettings', 'financialSettings', 'permissions', 'status'
           ]))
        )
      );

      match /members/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && (isOwner(userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin());
      }
    }

    // Eventos e Ocorrências
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isAdmin() || (isNotBlocked() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor'])));
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /recurring_events/{docId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /recurring_occurrences/{docId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /usernames/{username} { allow read: if true; allow create: if isSignedIn(); }
    
    // Anúncios e Métricas
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin']);
      match /viewers/{userId} { 
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin(); 
      }
    }

    // Registros e Transações (Protegidos)
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance']));
      allow create, delete: if isAdmin(); // Ingressos apenas via Server/Admin
      allow update: if isAdmin() || (isSignedIn() && hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']));
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; 
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // Logs e Emails
    match /system_logs/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /sent_emails/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /tax_tickets/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /tax_ads/{docId} { allow read, write: if isAdmin(); }
  }
}