
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) ||
        getUserData().role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
      );
    }

    // --- REGRAS POR COLEÇÃO ---

    // Configurações Globais (Site, Taxas, etc) - Leitura Pública Necessária
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      // Eventos 'draft' são privados ao dono
      allow read: if (resource.data.status != 'draft') || isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin() || isOrgMember(resource.data.organizationId);
      allow delete: if isAdmin() || isOwner(resource.data.userId);

      match /interests/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || isOwner(userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(orgId);
    }
    
    // Fallback genérico (mantendo compatibilidade com outras coleções)
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
