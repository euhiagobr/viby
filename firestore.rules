
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) ||
        getUserData().role == 'admin'
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        (exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/system_admins/$(request.auth.uid)).data.cargo == 'super_admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
      );
    }

    // --- REGRAS POR COLEÇÃO ---

    // Material de Marca Viby (Exclusivo)
    match /brand_assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações Globais
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cityPages/{cityId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || isOwner(userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(orgId);

      match /members/{memberId} {
        allow read: if isSignedIn() || isAdmin();
        allow create, update, delete: if isAdmin() || isOrgMember(orgId);
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(request.resource.data.organizationId);
      allow delete: if isAdmin() || isOrgMember(resource.data.organizationId);

      match /interests/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.userId || isOrgMember(resource.data.organizationId)));
      allow create: if isSignedIn(); 
      allow update: if isAdmin();
    }

    match /support_tickets/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /sent_emails/{id} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /system_logs/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
