
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2"
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || true; // Public for social profiles
      allow write: if isOwner(userId) || isAdmin();
      
      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Usernames Index - PUBLICO PARA VALIDACAO
    match /usernames/{username} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }

    // Affiliate System - PUBLICO PARA VALIDACAO NO CADASTRO
    match /affiliateCodes/{code} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /affiliate_commissions/{commissionId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.affiliateId || isAdmin());
      allow write: if false; // Server-only
    }

    match /affiliate_stats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Server-only
    }

    match /affiliate_payouts/{payoutId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Organizations and Members
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if request.auth != null && (isOwner(resource.data.ownerId) || isAdmin() || request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2");

      match /members/{userId} {
         allow read, write: if request.auth != null && (isOwner(userId) || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId);
      }
    }

    // Events and Registrations
    match /events/{eventId} { 
      allow read: if true; 
      allow write: if request.auth != null;
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      
      match /interests/{interestId} {
        allow read, write: if request.auth != null;
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /registrations/{regId} {
      allow read: if request.auth != null && (isOwner(resource.data.userId) || isAdmin() || get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.ownerId == request.auth.uid);
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Wallet
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /wallet_transactions/{txId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Admin Specific
    match /system_admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /sent_emails/{emailId} {
      allow read: if isAdmin();
      allow write: if false; // Server actions only
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // General catch-all for admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
