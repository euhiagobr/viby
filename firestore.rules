
rules_version = '2';
service cloud.firestore {
  match /databases/(default)/documents {
    // REGRAS ONG - Versão: 2.0.0
    // Estas regras aplicam-se apenas ao banco de dados (default)
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
