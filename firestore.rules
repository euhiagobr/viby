
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções Auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Coleção de Eventos: 
    // - Qualquer pessoa pode ler (divulgação pública)
    // - Apenas usuários logados podem criar
    // - Apenas o criador (organizerId) pode editar ou deletar
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.organizerId == request.auth.uid;
    }

    // Coleção de Usuários/Organizadores:
    // - Qualquer pessoa pode ler o perfil do organizador para verificação de credibilidade
    // - Apenas o próprio dono pode editar seus dados
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Coleção de Registros/Interesses:
    // - Usuários logados podem criar seu registro de interesse
    // - Organizadores podem ver quem está interessado em seus eventos
    match /registrations/{regId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid);
    }
  }
}
