
rules_version = '2';
service cloud.firestore {
  match /databases/(default)/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function getRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function hasRole(orgId, roles) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) && getRole(orgId) in roles;
    }

    // --- LEITURA PÚBLICA ---
    match /users/{userId} {
      allow read: if true;
      allow write: if isUser(userId) || isAdmin();
      
      match /private/sensitive {
        allow read, write: if isUser(userId) || isAdmin();
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasRole(orgId, ['owner', 'admin']) || isAdmin();
      allow delete: if hasRole(orgId, ['owner']) || isAdmin();

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasRole(orgId, ['owner', 'admin']) || isAdmin());
        allow write: if hasRole(orgId, ['owner', 'admin']) || isAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if hasRole(resource.data.organizationId, ['owner', 'admin', 'editor']) || isAdmin();
      allow delete: if hasRole(resource.data.organizationId, ['owner', 'admin']) || isAdmin();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
      
      match /likes/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /categories/{catId} {
      allow read: if true;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // --- PRIVADO ---
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.sharedWithUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.targetUid == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.targetUid == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
