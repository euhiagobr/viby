rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isServer() {
      return request.auth == null;
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- REGRAS POR COLEÇÃO (LEITURA PÚBLICA TOTAL) ---

    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /events/{id} { 
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow delete: if isAdmin() || isMemberOfOrg(resource.data.organizationId);
      
      match /partners/{p} { allow read: if true; allow write: if isSignedIn(); }
      match /interests/{u} { allow read: if true; allow write: if isSignedIn() && request.auth.uid == u; }
      match /comments/{c} { allow read: if true; allow create: if isSignedIn(); allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); }
      match /setores/{s} { allow read: if true; allow write: if isSignedIn(); match /assentos/{a} { allow read: if true; allow write: if isSignedIn(); } }
    }

    match /organizations/{id} { 
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isAdmin() || isMemberOfOrg(id);
      match /members/{m} { allow read: if true; allow write: if isAdmin() || isMemberOfOrg(id) || (isSignedIn() && m == request.auth.uid); }
      match /transactions/{t} { allow read: if isAdmin() || isMemberOfOrg(id); allow write: if isServer() || isAdmin(); }
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      match /private/sensitive { allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId); }
    }

    match /registrations/{id} {
      allow read: if true;
      allow create: if isServer();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId) || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    match /ads/{id} { allow read: if true; allow write: if isServer() || isAdmin() || isMemberOfOrg(request.resource.data.organizationId); }
    match /orders/{id} { allow read: if isServer() || isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId); allow create: if isSignedIn(); allow update: if isServer() || isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /usernames/{id} { allow read: if true; allow write: if isSignedIn() || isServer(); }
    match /recurring_occurrences/{id} { allow read: if true; allow write: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId); }
    match /financial_logs/{id} { allow read: if isAdmin(); allow create: if isServer() || isAdmin(); }
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if true; }
    match /sent_emails/{id} { allow read: if isAdmin(); allow create: if isServer(); }
    match /follows/{id} { allow read: if true; allow create: if isSignedIn(); allow delete: if isSignedIn(); }
  }
}