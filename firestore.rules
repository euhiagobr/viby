
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2"
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users can read their own data and admins can read all user data
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      // Sensitive data subcollection
      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Organizations can be read by anyone, but only written to by owners/admins
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if request.auth != null && (isOwner(resource.data.ownerId) || isAdmin() || request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2");

      match /members/{userId} {
         allow read, write: if request.auth != null && (isOwner(userId) || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId);
      }
    }

    // Affiliate System
    match /affiliateCodes/{code} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /affiliate_commissions/{commissionId} {
        allow read: if request.auth != null && (request.auth.uid == resource.data.affiliateId || isAdmin());
        allow write: if false; // Server-only
    }

    match /affiliate_stats/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Server-only
    }

    match /affiliate_payouts/{payoutId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
        allow update, delete: if isAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.targetUid;
      allow create, delete: if isAdmin();
    }

    // Gamification
    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if request.auth != null && (isOwner(resource.data.userId) || isAdmin());
      allow write: if isAdmin();
    }

    // Financial Ledger (ERP)
    match /tax_tickets/{taxId} { allow read: if isAdmin(); }
    match /tax_ads/{taxId} { allow read: if isAdmin(); }
    match /internal_expenses/{id} { allow read, write: if isAdmin(); }

    // General match for other public collections
    match /categories/{catId} { allow read: if true; }
    match /events/{eventId} { 
      allow read: if true; 
      allow write: if request.auth != null;
    }
    match /usernames/{username} { allow read: if true; }
    match /ads/{adId} { allow read: if true; }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }

    // General catch-all
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
