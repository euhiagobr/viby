
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO GLOBAIS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        (exists(/databases/$(database)/documents/system_admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/system_admins/$(request.auth.uid)).data.cargo == 'super_admin')
      );
    }

    // --- HIERARQUIA DE ORGANIZAÇÃO ---

    function getMemberData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isOrgOwner(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        getMemberData(orgId).role == 'owner'
      );
    }

    function isOrgAdmin(orgId) {
      return isSignedIn() && (isOrgOwner(orgId) || getMemberData(orgId).role == 'admin');
    }

    function isOrgEditor(orgId) {
      return isSignedIn() && (isOrgAdmin(orgId) || getMemberData(orgId).role == 'editor');
    }

    function isOrgMember(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- REGRAS POR COLEÇÃO ---

    match /system_admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /usernames/{username} { 
      allow read: if true; 
      allow create, delete: if isSignedIn() && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgAdmin(orgId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt']));

      match /members/{memberId} {
        allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == memberId || isOrgMember(orgId)));
        allow create: if isSignedIn() && (isAdmin() || request.auth.uid == memberId || isOrgAdmin(orgId));
        allow update, delete: if isAdmin() || isOrgAdmin(orgId);
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isOrgEditor(request.resource.data.organizationId);
      allow update: if isAdmin() || isOrgEditor(resource.data.organizationId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedCount', 'viewsCount', 'sharesCount', 'goingCount', 'updatedAt', 'ingressosVendidos']));
      allow delete: if isAdmin() || isOrgEditor(resource.data.organizationId);

      match /interests/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.userId || isOrgMember(resource.data.organizationId)));
      allow create: if isSignedIn(); 
      allow update: if isAdmin() || (isSignedIn() && isOrgMember(resource.data.organizationId));
    }

    match /follows/{followId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /user_gamification/{uid} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /cultural_stats/{uid} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /xp_logs/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /xp_rules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliateCodes/{code} {
      allow read, list: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == request.resource.data.userId);
    }

    match /affiliate_stats/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin(); 
    }

    match /support_tickets/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.targetUid == request.auth.uid;
      allow write: if isAdmin();
    }

    match /system_logs/{id} {
      allow read, write: if isAdmin();
    }
    
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
