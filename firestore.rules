rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- FUNÇÕES DE APOIO ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isNotBlocked(data) {
      return !data.keys().contains('status') || data.status != 'Bloqueado';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE CONFIGURAÇÃO E LOGS ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_logs/{logId} {
      allow create: if true; 
      allow read, list, update, delete: if isAdmin();
    }

    match /sent_emails/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- REGRAS DE EVENTOS E ORGANIZAÇÕES ---
    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn() && isNotBlocked(get(/databases/$(database)/documents/users/$(request.auth.uid)).data); 

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked(get(/databases/$(database)/documents/users/$(request.auth.uid)).data);
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /recurring_events/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && isNotBlocked(get(/databases/$(database)/documents/users/$(request.auth.uid)).data);
    }

    match /recurring_occurrences/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && isNotBlocked(get(/databases/$(database)/documents/users/$(request.auth.uid)).data);
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow write: if isSignedIn() && isNotBlocked(get(/databases/$(database)/documents/users/$(request.auth.uid)).data);

      match /members/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin', 'editor', 'finance', 'checkin']) || isAdmin());
        allow write: if isSignedIn();
      }
      
      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if false; // Apenas servidor (Admin SDK)
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /viewers/{userId} {
        allow read, write: if isSignedIn();
      }
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- REGRAS DE NEGÓCIO: PEDIDOS E INGRESSOS (VIBY CORE PROTECTED) ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || isAdmin());
      allow create: if false; // BLOQUEIO CRÍTICO: Ingressos não podem ser criados pelo navegador
      allow update: if isSignedIn() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || isAdmin());
    }

    match /tax_tickets/{docId} {
      allow create: if false; // Apenas servidor
      allow read: if isAdmin();
    }

    match /tax_ads/{docId} {
      allow read, write: if isAdmin();
    }

    // --- REGRAS DE USUÁRIO, CARTEIRA E SOCIAL ---
    match /users/{userId} {
      allow read: if (isNotBlocked(resource.data)) || isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // BLOQUEIO CRÍTICO: Saldo protegido contra alterações via navegador
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false; // Apenas servidor
      allow update: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /internal_expenses/{docId} {
      allow read, write: if isAdmin();
    }

    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.followerId || request.auth.uid == resource.data.followerId);
    }

    // Segurança padrão para coleções não especificadas
    match /{allPaths=**} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}