rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isServer() {
      return request.auth == null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isFieldUnchanged(fieldName) {
      return !(fieldName in request.resource.data) || 
             (resource != null && request.resource.data[fieldName] == resource.data[fieldName]);
    }

    // --- REGRAS POR COLEÇÃO ---

    match /users/{userId} {
      // Perfil básico é público, mas campos sensíveis são protegidos por lógica de imutabilidade
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && isFieldUnchanged('cpf') && isFieldUnchanged('role') && isFieldUnchanged('totalXp'));
      
      match /private/sensitive {
        // Dados brutos (CPF real) nunca são públicos
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isMemberOfOrg(orgId);

      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(orgId) || isOwner(memberId);
      }

      match /transactions/{txId} {
        allow read: if isAdmin() || isMemberOfOrg(orgId);
        allow write: if isServer() || isAdmin(); 
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isSignedIn();
      // Permite que o servidor atualize contadores de estoque durante estornos/compras
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow delete: if isAdmin() || isMemberOfOrg(resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      
      match /setores/{sectorId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        
        match /assentos/{seatId} {
          allow read: if true;
          allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        }
      }
    }

    match /registrations/{regId} {
      // Leitura pública necessária para o scanner validar o ticketCode sem exigir login do porteiro em todos os casos
      allow read: if true; 
      allow create: if isServer(); // Apenas o servidor gera ingressos após pagamento
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId) || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    match /orders/{orderId} {
      // Pedidos são privados. O servidor precisa ler para finalizar o checkout.
      allow read: if isServer() || isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isServer() || isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin() || isMemberOfOrg(request.resource.data.organizationId);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wallets/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow write: if isServer() || isAdmin();
    }

    match /wallet_transactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isServer() || isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if true; 
      allow update: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
    }
    
    match /recurring_occurrences/{occId} {
      allow read: if true;
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow create: if isServer() || isAdmin() || isMemberOfOrg(request.resource.data.organizationId);
    }

    match /usernames/{username} { allow read: if true; allow write: if isSignedIn() || isServer(); }
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if true; allow update: if isAdmin(); }
    match /financial_logs/{id} { allow read: if isAdmin(); allow create: if isServer() || isAdmin(); }
    match /tax_tickets/{id} { allow read: if isAdmin(); allow write: if isServer(); }
    match /tax_ads/{id} { allow read: if isAdmin(); allow write: if isServer(); }
    
    match /support_tickets/{id} { 
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); 
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /ads/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
    }

    match /password_reset_codes/{docId} {
      allow read: if true;
      allow write: if isServer() || isAdmin();
    }

    match /sent_emails/{id} {
      allow read: if isAdmin();
      allow create: if isServer();
    }
    
    match /user_gamification/{uid} { 
      allow read: if true; 
      allow write: if isServer() || isAdmin() || isOwner(uid); 
    }
    
    match /xp_logs/{id} { 
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); 
      allow write: if isServer() || isAdmin(); 
    }
    
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.followerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.followerId;
    }
  }
}