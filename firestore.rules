
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read their own data and admins can read all user data
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Organizations can be read by anyone, but only written to by owners/admins
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /organizations/{orgId}/members/{userId} {
       allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId);
    }

    // Affiliate Codes: Public read for validation during signup
    match /affiliateCodes/{code} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Affiliate Commissions: Only the affiliate or admin can read
    match /affiliate_commissions/{commissionId} {
        allow read: if request.auth != null && (request.auth.uid == resource.data.affiliateId || isAdmin());
        allow write: if false; // Server-only
    }

    match /affiliate_stats/{userId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if false; // Server-only
    }

    match /affiliate_payouts/{payoutId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
        allow update, delete: if isAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // General match for other public collections
    match /categories/{catId} { allow read: if true; }
    match /events/{eventId} { allow read: if true; }
    match /usernames/{username} { allow read: if true; }

    // General catch-all to deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
