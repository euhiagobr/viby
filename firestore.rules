rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE SEGURANÇA ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNotBlocked() {
      return !isSignedIn() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'Ativo') != 'Bloqueado';
    }

    // --- REGRA DE OURO (SUPERUSER) ---
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- REGRAS DE COLEÇÃO ---

    match /settings/{docId} { allow read: if true; }
    match /categories/{catId} { allow read: if true; }
    match /usernames/{username} { allow read: if true; }
    
    match /events/{eventId} { 
      allow read: if true; 
      allow update: if (isSignedIn() && isNotBlocked()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ingressosVendidos', 'updatedAt']));
    }

    match /recurring_occurrences/{docId} { 
      allow read: if true; 
      allow update: if (isSignedIn() && isNotBlocked()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ingressosVendidos', 'updatedAt']));
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      
      allow update: if (isSignedIn() && isNotBlocked() && request.auth.uid == resource.data.ownerId) || 
        (
          request.auth == null && 
          request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'stripeAccountId', 
            'stripeOnboardingComplete', 
            'stripeChargesEnabled', 
            'stripePayoutsEnabled', 
            'stripeDetailsSubmitted',
            'payoutSettings',
            'adBalance',
            'blockedBalance',
            'updatedAt'
          ])
        );

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isNotBlocked();
      }
      
      match /transactions/{txId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() || request.auth == null;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && isNotBlocked();

      match /private/sensitive {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /registrations/{regId} {
      allow read: if isSignedIn() || resource.data.checkedIn == true;
      allow create: if isSignedIn() || (request.auth == null && request.resource.data.paymentStatus == 'Pago');
      
      // Permitir estorno via Server Action (unauth)
      allow update: if isSignedIn() || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'status', 'paymentStatus', 'refundId', 'refundType', 'refundedBy', 'refundedAt', 'refundExecutorId', 'updatedAt'
        ]));
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if (isSignedIn() && (resource.data.userId == request.auth.uid)) || request.auth == null;
      allow update: if (isSignedIn() && (resource.data.userId == request.auth.uid)) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'stripeSessionId', 'updatedAt']));
    }

    match /financial_logs/{logId} {
      allow create: if true; // Permitir auditoria via Server Action
      allow read: if isAdmin();
    }

    match /tax_ads/{docId} {
      allow create: if request.auth == null;
      allow update: if request.auth == null;
    }

    match /payout_requests/{docId} {
      allow read, create: if isSignedIn();
    }

    match /support_tickets/{ticketId} {
      allow read, create: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow update: if isSignedIn();
    }
    
    match /system_logs/{logId} {
      allow create: if true; 
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
    }

    match /sent_emails/{docId} {
      allow read: if isSignedIn() && (resource.data.recipientEmail == request.auth.token.email);
    }
    
    match /follows/{followId} { allow read: if true; }
    match /user_gamification/{userId} { allow read: if true; }
  }
}