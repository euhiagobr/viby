
rules_version = '2';
service cloud.firestore {
  match /databases/(default)/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- LEITURA PÚBLICA TOTAL ---
    match /users/{userId} {
      allow read, get, list: if true;
      allow write: if isUser(userId) || isAdmin();
      
      match /private/sensitive {
        allow read, write: if isUser(userId) || isAdmin();
      }
    }

    match /organizations/{orgId} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();

      match /members/{userId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() || isAdmin();
      }
    }

    match /events/{eventId} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() || isAdmin();
      
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /categories/{catId} {
      allow read, get, list: if true;
    }

    match /usernames/{username} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /ads/{adId} {
      allow read, get, list: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // --- PRIVADO ---
    match /registrations/{regId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() || isAdmin();
    }

    match /notifications/{notifId} {
      allow read, get, list: if isSignedIn() && resource.data.targetUid == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.targetUid == request.auth.uid;
    }

    match /{allPaths=**} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
