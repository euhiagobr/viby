rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE APOIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário autenticado é um Administrador Global
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Garante que o usuário não está bloqueado
    function isNotBlocked() {
      return !isSignedIn() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'Ativo') != 'Bloqueado';
    }

    // --- REGRAS DE ACESSO ---

    // 1. REGRA DE OURO (SUPERUSER): Admin Global tem poder total em qualquer coleção
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // 2. Acesso Público (Leitura Livre para Descoberta)
    match /settings/{docId} { allow read: if true; }
    match /categories/{catId} { allow read: if true; }
    match /usernames/{username} { allow read: if true; }
    match /events/{eventId} { allow read: if true; }
    match /organizations/{orgId} { allow read: if true; }
    match /recurring_events/{docId} { allow read: if true; }
    match /recurring_occurrences/{docId} { allow read: if true; }
    match /ads/{adId} { allow read: if true; }
    match /users/{userId} { allow read: if true; }
    match /user_gamification/{userId} { allow read: if true; }
    match /follows/{followId} { allow read: if true; }
    match /badges/{badgeId} { allow read: if true; }
    match /xp_rules/{ruleId} { allow read: if true; }
    match /coupons/{couponId} { allow read: if true; }
    match /comments/{commentId} { allow read: if true; }
    match /interests/{userId} { allow read: if true; }

    // 3. Usuários (Gestão de Perfil)
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && isNotBlocked() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'adminFlags', 'permissions'
        ]);

      match /private/sensitive {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 4. Organizações
    match /organizations/{orgId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isNotBlocked();

      match /members/{userId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /transactions/{txId} {
        allow read: if isSignedIn();
      }
    }

    // 5. Eventos e Bilheteria
    match /events/{eventId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isNotBlocked();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /setores/{setorId} {
        allow read: if true;
        match /assentos/{assentoId} {
          allow read: if true;
          allow update: if isSignedIn();
        }
      }
    }

    // 6. Registros, Financeiro e Logs
    match /registrations/{regId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /wallets/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /support_tickets/{ticketId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
    }
    
    match /system_logs/{logId} {
      allow create: if true; 
    }

    match /sent_emails/{emailId} {
      allow create: if isSignedIn();
    }

    match /tax_ads/{docId} { allow read: if isSignedIn(); }
    match /tax_tickets/{docId} { allow read: if isSignedIn(); }
  }
}
