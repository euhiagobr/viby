rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE APOIO ROBUSTAS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica se o usuário autenticado é um Administrador Global
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Garante que o usuário não está bloqueado sem quebrar para visitantes
    function isNotBlocked() {
      if (!isSignedIn()) return true;
      if (!exists(/databases/$(database)/documents/users/$(request.auth.uid))) return true;
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !userData.keys().contains('status') || userData.status != 'Bloqueado';
    }

    // Verifica cargo em uma organização específica
    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE ACESSO PÚBLICO (DESCOBERTA) ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && isNotBlocked() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'adminFlags', 'permissions', 'totalXp', 'level'
        ])) || isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isAdmin() || (
        isNotBlocked() && (
          (hasOrgRole(orgId, ['owner']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verified', 'status', 'plan'])) ||
          (hasOrgRole(orgId, ['admin']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'ownerId', 'verified', 'plan', 'stripeAccountId', 
             'payoutSettings', 'financialSettings', 'permissions', 'status'
           ]))
        )
      );

      match /members/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && (isOwner(userId) || hasOrgRole(orgId, ['owner', 'admin']) || isAdmin());
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) && isNotBlocked()) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
      match /interests/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /recurring_events/{docId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /recurring_occurrences/{docId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /usernames/{username} { allow read: if true; allow create: if isSignedIn(); }
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin']);
      match /viewers/{userId} { allow read: if true; allow write: if isOwner(userId); }
    }
    match /coupons/{couponId} { allow read: if true; allow write: if isSignedIn() && isNotBlocked(); }
    match /user_gamification/{userId} { allow read: if true; allow write: if isAdmin(); }
    match /follows/{followId} { 
      allow read: if true; 
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.followerId || (resource != null && request.auth.uid == resource.data.followerId)); 
    }

    // --- REGRAS DE NEGÓCIO E PROTEÇÃO (RESTRITAS) ---

    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance']) || isAdmin());
      allow create: if false; // EMISSÃO APENAS VIA SERVER/ADMIN SDK
      allow update: if isSignedIn() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || isAdmin());
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // SALDO BLINDADO NO CLIENTE
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /tax_tickets/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /tax_ads/{docId} { allow read, write: if isAdmin(); }
    match /system_logs/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /sent_emails/{logId} { allow create: if true; allow read: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /xp_logs/{logId} { allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); allow write: if isAdmin(); }
    match /reports/{reportId} { allow create: if isSignedIn(); allow read: if isAdmin(); }
    match /support_tickets/{ticketId} { allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); allow create: if isSignedIn(); allow update: if isSignedIn(); }
    
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.targetUid) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    // Segurança padrão para coleções não mapeadas
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
