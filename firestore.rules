rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- FUNÇÕES DE APOIO ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isNotBlocked() {
      // Se o usuário não existe no Firestore ainda (novo cadastro), permite prosseguir
      if (!exists(/databases/$(database)/documents/users/$(request.auth.uid))) {
        return true;
      }
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !userData.keys().contains('status') || userData.status != 'Bloqueado';
    }

    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE CONFIGURAÇÃO E LOGS ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_logs/{logId} {
      allow create: if true; 
      allow read, list, update, delete: if isAdmin();
    }

    match /sent_emails/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- REGRAS DE EVENTOS E ORGANIZAÇÕES ---
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']) && isNotBlocked()) || isAdmin();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /recurring_events/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && isNotBlocked();
    }

    match /recurring_occurrences/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && isNotBlocked();
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isAdmin() || (
        isNotBlocked() && (
          (hasOrgRole(orgId, ['owner']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'verified', 'status', 'plan'
           ])) ||
          (hasOrgRole(orgId, ['admin']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'ownerId', 'verified', 'plan', 'stripeAccountId', 
             'payoutSettings', 'financialSettings', 'permissions', 'status'
           ]))
        )
      );

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      
      match /transactions/{txId} {
        allow read: if hasOrgRole(orgId, ['owner', 'admin', 'finance']) || isAdmin();
        allow create: if false;
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /viewers/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- REGRAS DE NEGÓCIO ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance']) || isAdmin());
      allow create: if false; 
      allow update: if isSignedIn() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']) || isAdmin());
    }

    match /tax_tickets/{docId} {
      allow create: if false;
      allow read: if isAdmin();
    }

    match /tax_ads/{docId} {
      allow read, write: if isAdmin();
    }

    // --- REGRAS DE USUÁRIO E CARTEIRA ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && 
        isNotBlocked() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'adminFlags', 'permissions', 'totalXp', 'level'
        ])) || isAdmin();

      match /private/sensitive {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false;
    }

    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.targetUid) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.targetUid) || isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /internal_expenses/{docId} {
      allow read, write: if isAdmin();
    }

    match /user_gamification/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /xp_logs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.followerId || request.auth.uid == resource.data.followerId);
    }

    // Segurança padrão
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
