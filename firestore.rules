rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isServer() {
      return request.auth == null;
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- REGRAS POR COLEÇÃO ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isMemberOfOrg(orgId);

      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(orgId) || (isSignedIn() && memberId == request.auth.uid);
      }

      match /transactions/{txId} {
        allow read: if isAdmin() || isMemberOfOrg(orgId);
        allow write: if isServer() || isAdmin(); 
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isSignedIn();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow delete: if isAdmin() || isMemberOfOrg(resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      
      match /setores/{sectorId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        
        match /assentos/{seatId} {
          allow read: if true;
          allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        }
      }
    }

    match /registrations/{regId} {
      allow read: if true;
      allow create: if isServer();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId) || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isServer() || isAdmin();
    }

    match /coupons/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isMemberOfOrg(resource.data.organizationId);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wallets/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isServer() || isAdmin();
    }

    match /wallet_transactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isServer() || isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if true; 
      allow update: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
    }
    
    match /usernames/{username} { allow read: if true; allow write: if isSignedIn() || isServer(); }
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if true; allow update: if isAdmin(); }
    match /financial_logs/{id} { allow read: if isAdmin(); allow create: if isServer() || isAdmin(); }
    match /tax_tickets/{id} { allow read: if isAdmin(); allow write: if isServer(); }
    match /tax_ads/{id} { allow read: if isAdmin(); allow write: if isServer(); }
    match /support_tickets/{id} { 
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}