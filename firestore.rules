
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- REGRAS DE PLATAFORMA (EXPERIÊNCIAS + SLOTS + STRIPE) ---
    // 1. RESERVATION LOCK: Checkout exige reserva válida 'reserved' e não expirada.
    // 2. SOLD AUTHORITY: 'sold' é atualizado EXCLUSIVAMENTE via webhook Stripe.
    // 3. IDEMPOTÊNCIA: Eventos Stripe devem ser idempotentes por event_id.
    // 4. WEBHOOK AUTHORITY: Webhook é a única fonte de verdade de pagamento.
    // 5. EXPIRAÇÃO SEGURA: Expiração não interfere em pagamentos em andamento ou confirmados.
    // 6. CONSISTÊNCIA FINANCEIRA: 'order' é a fonte de verdade; price_snapshot é imutável.
    // 7. CONCORRÊNCIA: Operações de slot devem ser atômicas e considerar sold + reserved ativos.
    // 8. JOB SAFETY: Workers devem usar system_job_locks.

    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/system_admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
      );
    }

    // --- REGRAS PÚBLICAS (Acesso de leitura para todos) ---

    // Avaliações de Experiência
    match /experience_reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Configurações do Site, Logo e Branding
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações de Sistema (Google Ads, etc)
    match /system_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campanhas de Simulação e Cupons Ads (Leitura pública para validação)
    match /simulation_campaigns/{campId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ad_coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Recuperação de Senha (OTP)
    match /password_reset_codes/{codeId} {
      allow create: if true;
      allow read, update: if true; // Validação cega (exige saber o ID do documento)
    }

    // Índice de Unicidade e Rotas
    match /usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Categorias de Filtro
    match /categories/{category} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Páginas de Cidades (SEO)
    match /cityPages/{cityId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Ocorrências e Sessões de Eventos
    match /recurring_occurrences/{occId} {
      allow read: if true;
      allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
    }

    // Campanhas de Anúncios (Cards Patrocinados)
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin() || isOrgMember(resource.data.organizationId);
    }

    // Eventos Ativos e Públicos
    match /events/{eventId} {
      allow read: if (resource.data.status == 'Ativo') || (resource.data.status == 'Oculto') || isAdmin() || isOrgMember(resource.data.organizationId) || isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOrgMember(resource.data.organizationId) || isOwner(resource.data.userId);

      match /interests/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgMember(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    // Perfis de Organizações
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(orgId);
      
      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isOwner(orgId) || isOwner(memberId);
      }

      // --- MÓDULO DE CARDÁPIO ---
      match /menu_sections/{sectionId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgMember(orgId);
      }

      match /menu_items/{itemId} {
        allow read: if true;
        allow write: if isAdmin() || isOrgMember(orgId);
      }
    }

    // Perfis de Usuários (Dados básicos)
    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // --- REGRAS RESTRITAS (Apenas Admin ou Dono) ---
    
    // Reservas Temporárias de Experiência (Hold)
    match /experience_reservations/{resId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Criação/Manutenção via Server Action
    }

    // Módulo de Parceiros Estratégicos
    match /partners/{partnerId} {
      allow read: if isOwner(partnerId) || isAdmin();
      allow write: if isAdmin();
    }
    match /partner_referrals/{refId} {
      allow read: if isSignedIn() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /partner_commissions/{commId} {
      allow read: if isSignedIn() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /partner_withdrawals/{drawId} {
      allow read: if isSignedIn() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || isOwner(resource.data.userId) || isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOrgMember(resource.data.organizationId);
    }

    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }

    match /wallets/{userId} {
      allow read: if isAdmin() || isOwner(userId);
    }

    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; 
    }

    // Fallback de segurança
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
