rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== FUNÇÕES AUXILIARES GLOBAIS =====

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnDoc(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ongRole == "admin" ||
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles != null &&
          "admin" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles));
    }

    function getUserType() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type;
    }

    function isDiretoria() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        userData.type == "diretoria" ||
        userData.ongRole == "diretor" ||
        userData.ongRole == "diretoria" ||
        (userData.roles != null &&
         ("diretoria" in userData.roles ||
          "director" in userData.roles))
      );
    }

    function isAdminMaster() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMaster == true;
    }

    function canViewMeeting(meeting) {
      return isAdmin() ||
        (meeting.visibilidade == "publico" && isSignedIn()) ||
        (meeting.visibilidade == "voluntarios" && isSignedIn() &&
          (getUserType() == "voluntario" || getUserType() == "diretoria")) ||
        (meeting.visibilidade == "diretoria" && isSignedIn() &&
          getUserType() == "diretoria");
    }

    // ===== FUNÇÕES DO BLOG =====

    function getBlogUserRole() {
      return (exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != null
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
            : (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ongRole != null
              ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ongRole
              : "guest"))
        : "guest";
    }

    function isBlogAdmin() {
      let role = getBlogUserRole();
      return role == "admin" || role == "director" || role == "diretor";
    }

    function canCreateBlogPost() {
      let role = getBlogUserRole();
      return role == "admin" || role == "director" || role == "volunteer" || role == "diretor";
    }

    // ===== USUÁRIOS =====
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwnDoc(uid);
      allow update: if isSignedIn() && (
        (isOwnDoc(uid) && !("type" in request.resource.data.diff(resource.data).affectedKeys())) ||
        isAdmin() ||
        (getUserType() == "diretoria" &&
          request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
          "type" in request.resource.data.diff(resource.data).affectedKeys())
      ) &&
        !("parentalConsentStatus" in request.resource.data.diff(resource.data).affectedKeys()) &&
        !("parentalConsentApprovedAt" in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isSignedIn() && isOwnDoc(uid);

      // Subcoleção de perfil de usuário
      match /profile/{document=**} {
        allow read: if isSignedIn() && isOwnDoc(uid);
        allow write: if isSignedIn() && isOwnDoc(uid);
      }

      // Logs/atividades do usuário
      match /activity/{document=**} {
        allow read: if isSignedIn() && (isOwnDoc(uid) || isAdmin());
        allow create: if isSignedIn() && isOwnDoc(uid);
        allow update, delete: if isAdmin();
      }

      // Consentimentos LGPD
      match /user_consents/{consentId} {
        allow read: if isSignedIn() && isOwnDoc(uid);
        allow read: if isAdminMaster();
        allow create: if request.auth == null &&
          request.resource.data.userId == uid &&
          request.resource.data.consentType != null &&
          (request.resource.data.consentType in ['terms', 'privacy', 'lgpd']) &&
          request.resource.data.version != null &&
          request.resource.data.accepted == true &&
          request.resource.data.acceptedAt != null &&
          request.resource.data.ipHash != null &&
          request.resource.data.userAgent != null &&
          request.resource.data.legalBasis == 'consent';
        allow update: if false;
        allow delete: if isSignedIn() && isOwnDoc(uid);
      }

      // Consentimentos Parentais
      match /parental_consents/{consentId} {
        allow read: if isSignedIn() && isOwnDoc(uid);
        allow read: if isAdminMaster();
        allow create: if request.auth == null &&
          request.resource.data.status == 'pending' &&
          request.resource.data.tokenHash != null &&
          request.resource.data.parentEmail != null &&
          request.resource.data.parentName != null &&
          request.resource.data.minorName != null &&
          request.resource.data.expiresAt != null &&
          request.resource.data.createdAt != null &&
          request.resource.data.isEditable == false;
        allow update: if request.auth == null && (
          (request.resource.data.status in ['approved', 'rejected', 'expired'] &&
           resource.data.status == 'pending') ||
          request.resource.data.approvedAt != null ||
          request.resource.data.expiredAt != null
        ) &&
          !(
            "tokenHash" in request.resource.data.diff(resource.data).affectedKeys() ||
            "userId" in request.resource.data.diff(resource.data).affectedKeys() ||
            "createdAt" in request.resource.data.diff(resource.data).affectedKeys()
          );
        allow delete: if isSignedIn() && isOwnDoc(uid);
      }

      // Revogações de consentimento
      match /consent_revocations/{revocationId} {
        allow read: if isSignedIn() && isOwnDoc(uid);
        allow create: if isSignedIn() && isOwnDoc(uid) &&
          request.resource.data.revokedAt != null;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ===== VAGAS =====
    match /vacancies/{vacancy} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== CANDIDATURAS =====
    match /applications/{application} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ===== DIRETORIAS REGIONAIS =====
    match /regionalDirectors/{director} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== VAGAS REGIONAIS =====
    match /regionalVacancies/{vacancy} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== CANDIDATURAS REGIONAIS =====
    match /regionalApplications/{application} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ===== CONFIGURAÇÕES DA ONG =====
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== FORMULÁRIOS =====
    match /forms/{formId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /fields/{fieldId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    // ===== RESPOSTAS DOS FORMULÁRIOS =====
    match /formResponses/{responseId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ===== EVENTOS =====
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== PROJETOS =====
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // ===== REUNIÕES =====
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if isAdmin() && request.resource.data.criadorId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.criadorId == request.auth.uid) ||
        isSignedIn();
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.criadorId == request.auth.uid);
    }

    // ===== CALENDÁRIO DA DIRETORIA =====
    match /diretoria_calendar/{eventId} {
      allow read: if isAdmin() || isDiretoria();
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== BLOG - POSTS (NOVA ESTRUTURA) =====
    match /posts/{postId} {
      allow read: if
        resource.data.status == "published" ||
        (isSignedIn() && resource.data.authorId == request.auth.uid) ||
        (isSignedIn() && canCreateBlogPost());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        isBlogAdmin()
      );
      allow delete: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid && resource.data.status == "draft") ||
        isBlogAdmin()
      );
    }

    // ===== BLOG - LEGACY =====
    match /blog_posts/{document=**} {
      allow read: if true;
      allow create: if isSignedIn() && canCreateBlogPost();
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        isBlogAdmin()
      );
      allow delete: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid && resource.data.status == "draft") ||
        isBlogAdmin()
      );
    }

    // ===== BLOG - CATEGORIAS =====
    match /blog_categories/{document=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isBlogAdmin();
    }

    // ===== BLOG - TAGS =====
    match /blog_tags/{document=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isBlogAdmin();
    }

    // ===== BLOG - AD BLOCKS =====
    match /blog_ad_blocks/{document=**} {
      allow read: if !exists(resource) || resource.data.isActive == true;
      allow create, update, delete: if isSignedIn() && isBlogAdmin();
    }

    // ===== BLOG - RULES =====
    match /blog_rules/{document=**} {
      allow read: if true;
      allow update: if isSignedIn() && isBlogAdmin();
    }

    // ===== SYSTEM LOGS =====
    match /system_logs/{log=**} {
      allow read: if isAdminMaster();
      allow create: if
        request.resource.data.timestamp != null &&
        request.resource.data.type != null &&
        request.resource.data.action != null &&
        request.resource.data.ipHash != null &&
        request.resource.data.userAgent != null &&
        request.resource.data.metadata != null &&
        request.resource.data.severity != null &&
        request.resource.data.environment != null &&
        request.resource.data.source != null &&
        request.resource.data.dataRetentionDays != null &&
        request.resource.data.legalBasisForProcessing != null &&
        request.resource.data.isEditable == false &&
        (request.resource.data.type in ['auth', 'admin', 'system', 'consent', 'data', 'user', 'security', 'blog', 'events']) &&
        (request.resource.data.severity in ['info', 'warning', 'critical', 'error']) &&
        (request.resource.data.environment in ['production', 'staging', 'development']);
      allow update: if false;
      allow delete: if false;
    }

    // ===== AUDIT TRAIL =====
    match /audit_trail/{document=**} {
      allow read: if isAdmin() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMaster == true;
      allow create: if request.auth == null;
      allow update, delete: if false;
    }

    // ===== EVENTOS SUBMETIDOS =====
    match /submitted_events/{eventId} {
      allow read: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.submittedAt != null &&
        request.resource.data.eventName != null &&
        request.resource.data.location != null &&
        request.resource.data.organizerEmail != null &&
        request.resource.data.organizerName != null;
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }

    // ===== ANÚNCIOS DO SITE =====
    match /advertisements/{adId} {
      allow read: if (isSignedIn() && isAdmin()) ||
        resource.data.status == 'active';
      allow create: if isSignedIn() && isAdmin() &&
        request.resource.data.title != null &&
        request.resource.data.image != null &&
        request.resource.data.link != null &&
        request.resource.data.format != null &&
        request.resource.data.placement != null &&
        request.resource.data.startDate != null &&
        request.resource.data.endDate != null &&
        request.resource.data.status != null &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && isAdmin() &&
        request.resource.data.updatedBy == request.auth.uid;
      allow delete: if isSignedIn() && isAdmin();
    }

    // ===== MÉTRICAS DE ANÚNCIOS =====
    match /advertisement_metrics/{metricId} {
      allow read: if isSignedIn() && isAdmin();
      allow create: if request.resource.data.adId != null &&
        request.resource.data.type in ['impression', 'click'] &&
        request.resource.data.timestamp != null;
      allow update, delete: if false;
    }

    // ===== DOAÇÕES =====
    match /donations/{donationId} {
      allow read: if isSignedIn() && isAdmin();
      allow create: if request.auth == null &&
        request.resource.data.sessionId != null &&
        request.resource.data.amount != null &&
        request.resource.data.currency != null &&
        request.resource.data.status in ['completed', 'pending', 'failed'] &&
        request.resource.data.paymentMethod != null &&
        (request.resource.data.paymentMethod in ['card', 'pix']) &&
        request.resource.data.donorName != null &&
        request.resource.data.userId != null &&
        request.resource.data.createdAt != null;
      allow update: if false;
      allow delete: if false;
    }

    // ===== STRIPE SESSIONS =====
    match /stripe_sessions/{sessionId} {
      allow read: if isSignedIn() && isAdmin();
      allow create, update: if request.auth == null &&
        request.resource.data.status != null;
      allow delete: if false;
    }

    // ===== DENÚNCIAS =====
    match /reports/{reportId} {
      allow read: if isSignedIn() && isAdmin();
      allow create: if
        request.resource.data.reportType != null &&
        (request.resource.data.reportType in ['discriminacao_orientacao_sexual', 'discriminacao_identidade_genero', 'lgbtfobia_violencia', 'violencia_institucional', 'assedio', 'outro']) &&
        request.resource.data.incidentDate != null &&
        request.resource.data.incidentCity != null &&
        request.resource.data.incidentLocation != null &&
        request.resource.data.description != null &&
        request.resource.data.supportTypes != null &&
        request.resource.data.supportTypes is list &&
        request.resource.data.declarationAccepted == true &&
        request.resource.data.isAnonymous != null &&
        request.resource.data.hasPhysicalViolence != null &&
        request.resource.data.hasWitnesses != null &&
        request.resource.data.hasPhotos != null &&
        request.resource.data.hasVideos != null &&
        request.resource.data.hasAudios != null &&
        request.resource.data.hasScreenshots != null &&
        request.resource.data.hasPreviousFormalReport != null &&
        request.resource.data.wantsAnonymousReport != null &&
        request.resource.data.authorizesAnonymousUsage != null &&
        request.resource.data.name != null &&
        request.resource.data.email != null &&
        request.resource.data.phone != null &&
        request.resource.data.age != null &&
        request.resource.data.genderIdentity != null &&
        request.resource.data.sexualOrientation != null &&
        request.resource.data.agressorIdentification != null &&
        request.resource.data.agressorRelation != null &&
        request.resource.data.fileUrls != null &&
        request.resource.data.fileUrls is list &&
        request.resource.data.fileUrls.size() > 0 &&
        request.resource.data.status == 'submitted';
      allow update: if isSignedIn() && isAdmin() &&
        request.resource.data.status in ['submitted', 'reviewing', 'resolved', 'archived'];
      allow delete: if isSignedIn() && isAdmin();
    }

    // ===== DOCUMENTOS DA ONG =====
    match /documentos/{documentoId} {
      allow read: if
        (isSignedIn() && resource.data.visibilidade == "publico") ||
        (isDiretoria() && (resource.data.visibilidade == "diretoria" || resource.data.visibilidade == "publico")) ||
        isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.nome != null &&
        request.resource.data.descricao != null &&
        request.resource.data.categoria != null &&
        (request.resource.data.categoria in ["documentos-ong", "atas-reunioes", "oficios"]) &&
        request.resource.data.visibilidade != null &&
        (request.resource.data.visibilidade in ["publico", "diretoria"]) &&
        request.resource.data.uploadPor != null &&
        request.resource.data.nomeUsuario != null &&
        request.resource.data.arquivoUrl != null &&
        request.resource.data.criadoEm != null &&
        request.resource.data.criptografado != null
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== SOLICITAÇÕES DE DOCUMENTOS =====
    match /solicitacoes_documentos/{solicitacaoId} {
      allow read: if
        (isSignedIn() && resource.data.usuarioId == request.auth.uid) ||
        (isDiretoria() && resource.data.status == "pendente") ||
        (isDiretoria() && resource.data.respondidoPor == request.auth.uid) ||
        isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.usuarioId == request.auth.uid &&
        request.resource.data.nomeCompleto != null &&
        request.resource.data.documento != null &&
        request.resource.data.mensagem != null &&
        request.resource.data.status == "pendente" &&
        request.resource.data.criadoEm != null;
      allow update: if
        (isDiretoria() && resource.data.status == "pendente" &&
         request.resource.data.status == "respondida" &&
         request.resource.data.responstaArquivoUrl != null &&
         request.resource.data.respondidoEm != null &&
         request.resource.data.respondidoPor == request.auth.uid &&
         request.resource.data.nomeUsuario != null &&
         resource.data.usuarioId == request.resource.data.usuarioId) ||
        (isAdmin() && request.resource.data.status == "cancelada");
      allow delete: if isAdmin();
    }

    // ===== SLIDERS =====
    match /sliders/{sliderId} {
      allow read: if (isSignedIn() && isAdmin()) ||
        resource.data.status == 'ativo';
      allow create: if isAdmin() &&
        request.resource.data.texto != null &&
        request.resource.data.imagemPC != null &&
        request.resource.data.imagemCelular != null &&
        request.resource.data.order != null;
      allow update, delete: if isAdmin();
    }

    // ===== EMPRESAS =====
    match /empresas/{empresaId} {
      allow read, write: if isSignedIn() && isAdmin();
      allow read: if isSignedIn() && resource.data.status == 'aprovado';
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pendente' &&
        request.resource.data.keys().hasAny(['userId', 'nomeFantasia', 'razaoSocial', 'categorias', 'cep', 'endereco', 'numero', 'bairro', 'cidade', 'estado', 'pais', 'email', 'telefone', 'searchText', 'status', 'createdAt']);
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.status == resource.data.status &&
        !request.resource.data.keys().hasAny(['approvedBy', 'approvedAt', 'motivoRejeicao']);
      allow delete: if isSignedIn() &&
        resource.data.status == 'pendente';
    }

    // ===== USERNAMES =====
    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }

    // ===== TESOURARIA =====
    match /tesouraria_resumo/{docId} {
      allow read: if isAdmin() || isDiretoria();
      allow write: if isAdmin() || isDiretoria();
    }

    match /tesouraria_entradas/{entradaId} {
      allow read: if isAdmin() || isDiretoria();
      allow create: if isSignedIn() && (isAdmin() || isDiretoria()) &&
        request.resource.data.valor != null &&
        request.resource.data.status in ["previsto", "realizado"] &&
        request.resource.data.created_by == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || isDiretoria());
      allow delete: if isAdmin() || isDiretoria();
    }

    match /tesouraria_saidas/{saidaId} {
      allow read: if isAdmin() || isDiretoria();
      allow create: if isSignedIn() && (isAdmin() || isDiretoria());
      allow update: if isSignedIn() && (isAdmin() || isDiretoria());
      allow delete: if isAdmin() || isDiretoria();
    }

    match /tesouraria_mensalidades_config/{docId} {
      allow read: if isAdmin() || isDiretoria();
      allow write: if isAdmin() || isDiretoria();
    }

    match /tesouraria_mensalidades/{mensalidadeId} {
      allow read: if isAdmin() || isDiretoria() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isAdmin() || isDiretoria();
      allow update: if isAdmin() || isDiretoria() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["comprovante_url"]));
      allow delete: if isAdmin() || isDiretoria();
    }

    // ===== REDE DESAFIOS =====
    match /rede_categorias/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rede_profiles/{profileId} {
      allow read: if
        isAdmin() ||
        (resource.data.status == "aprovado" && resource.data.ativo == true && resource.data.deletado != true);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.userId == request.auth.uid &&
         !("userId" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("status" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("ativo" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("seloOng" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("deletado" in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /rede_servicos/{serviceId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (get(/databases/$(database)/documents/rede_profiles/$(resource.data.profileId)).data.status == "aprovado" &&
         get(/databases/$(database)/documents/rede_profiles/$(resource.data.profileId)).data.ativo == true)
      );
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /rede_sidebar/{sidebarId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rede_avaliacoes/{avaliacaoId} {
      allow read: if resource.data.ativo == true;
      allow create, update, delete: if request.auth != null;
    }

    match /rede_palavras_proibidas/{palavraId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /rede_views/{viewId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.profileId != null &&
        request.resource.data.month != null &&
        request.resource.data.day != null;
      allow update, delete: if false;
    }

    match /rede_ads/{adId} {
      allow read: if
        (isSignedIn() && resource.data.userId == request.auth.uid) ||
        resource.data.status == "active";
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == "pending_payment";
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         !("approvedBy" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("approvedAt" in request.resource.data.diff(resource.data).affectedKeys())) ||
        (isAdmin() && (
          "views" in request.resource.data.diff(resource.data).affectedKeys() ||
          "clicks" in request.resource.data.diff(resource.data).affectedKeys() ||
          "status" in request.resource.data.diff(resource.data).affectedKeys() ||
          "approvedBy" in request.resource.data.diff(resource.data).affectedKeys() ||
          "approvedAt" in request.resource.data.diff(resource.data).affectedKeys() ||
          "active" in request.resource.data.diff(resource.data).affectedKeys() ||
          "proofUrl" in request.resource.data.diff(resource.data).affectedKeys()
        ))
      );
      allow delete: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
    }

    // ===== FEIRA BAILE DA DIVERSIDADE =====
    match /feiraBaileDiversidade/empreendedores/cadastros/{cadastroId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["comprovanteUrl"])) ||
        (isAdmin() && request.resource.data.status in ['pendente', 'aprovado', 'rejeitado'])
      );
      allow delete: if isAdmin();
    }

    match /feiraBaileDiversidade/artistas/cadastros/{cadastroId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["comprovanteUrl"])) ||
        (isAdmin() && request.resource.data.status in ['pendente', 'aprovado', 'rejeitado'])
      );
      allow delete: if isAdmin();
    }

    // ===== APOIOS DA FEIRA BAILE DA DIVERSIDADE =====
    match /feiraBaileDiversidade/apoios/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== ATUAÇÕES =====
    match /atuacoes/{atuacaoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /trofeu/data/edicoes/{edicaoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /trofeu/data/indicacoes/{indicacaoId} {
      allow read: if isSignedIn() && (
        isAdmin() || resource.data.email == request.auth.token.email
      );
      allow create: if
        request.resource.data.edicaoId != null &&
        request.resource.data.categoriaId != null &&
        request.resource.data.telefone != null &&
        request.resource.data.nomeIndicado != null &&
        request.resource.data.justificativa != null &&
        request.resource.data.justificativa.size() >= 20 &&
        request.resource.data.justificativa.size() <= 300 &&
        request.resource.data.status == 'pendente';
      allow update, delete: if isAdmin();
    }

    match /trofeu/data/votos/{votoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /trofeu/data/periodsIndicacao/{periodoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /trofeu/data/configuracoesVotacao/{categoriaId} {
      allow read: if isSignedIn() && isAdmin();
      allow create, update: if isSignedIn() && isAdmin() &&
        request.resource.data.categoriaId != null &&
        request.resource.data.edicaoId != null &&
        request.resource.data.tipoVotacao != null &&
        (request.resource.data.tipoVotacao in ['ip', 'email']) &&
        request.resource.data.votosIlimitados != null &&
        request.resource.data.votosIlimitados is bool &&
        (request.resource.data.votosIlimitados == true ||
          (request.resource.data.quantidadeVotos != null &&
           request.resource.data.quantidadeVotos > 0 &&
           request.resource.data.quantidadeVotos <= 100 &&
           request.resource.data.intervalo != null &&
           (request.resource.data.intervalo in ['minuto', 'hora', 'dia'])));
      allow delete: if isAdmin();
    }

    match /trofeu/data/historicoVotos/{historicoId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.categoriaId != null &&
        request.resource.data.identificador != null &&
        request.resource.data.tipoIdentificador in ['ip', 'email'] &&
        request.resource.data.votoEm != null &&
        request.resource.data.proximoVotoDisponivel != null;
      allow update, delete: if false;
    }

    // ===== CONCURSOS =====
    match /concursos/{concursoId} {
      // Público pode ler concursos (exibir na página pública)
      allow read: if true;
      
      // Apenas admin pode criar, atualizar e deletar concursos
      allow create: if isAdmin() &&
        request.resource.data.nome != null &&
        request.resource.data.categorias != null &&
        request.resource.data.quantidadeFotos != null &&
        request.resource.data.dataAbertura != null &&
        request.resource.data.dataEncerramento != null &&
        request.resource.data.status != null &&
        request.resource.data.criadoPor == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Inscrições dos concursos (sub-coleção)
      match /inscricoes/{inscricaoId} {
        // Apenas o inscrito e admin podem ler inscrições
        allow read: if isSignedIn() && (
          resource.data.usuarioId == request.auth.uid ||
          isAdmin()
        );
        
        // Usuário autenticado pode criar sua inscrição
        allow create: if isSignedIn() &&
          inscricaoId == request.auth.uid &&
          request.resource.data.usuarioId == request.auth.uid &&
          request.resource.data.concursoId == concursoId &&
          request.resource.data.nomeCompleto != null &&
          request.resource.data.email != null &&
          request.resource.data.telefone != null &&
          request.resource.data.categoriaId != null &&
          request.resource.data.statusInscricao == 'pendente_analise' &&
          request.resource.data.statusPagamento in ['pendente', 'pago', 'gratuito'];
        
        // Apenas o inscrito pode atualizar suas fotos/comprovante, admin pode atualizar status
        allow update: if isSignedIn() && (
          (resource.data.usuarioId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fotosUrls", "comprovantePagamento", "atualizadoEm"])) ||
          (isAdmin() && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(["statusInscricao", "statusPagamento", "motivoRejeicao", "atualizadoEm"]))
        );
        
        // Apenas admin pode deletar
        allow delete: if isAdmin();
      }
    }

    // ===== RESULTADOS DE CONCURSOS =====
    match /concursos/{concursoId}/resultados/{resultadoId} {
      // Público pode ler resultados
      allow read: if true;
      
      // Apenas admin pode criar, atualizar e deletar resultados
      allow create, update, delete: if isAdmin();
    }

    // ===== BLOQUEIO PADRÃO =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}