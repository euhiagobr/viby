rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se é admin via token ou via campo no documento (resiliência para protótipos)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isServer() {
      return request.auth == null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isFieldUnchanged(fieldName) {
      return !(fieldName in request.resource.data) || 
             (resource != null && request.resource.data[fieldName] == resource.data[fieldName]);
    }

    // --- REGRAS POR COLEÇÃO ---

    // Usuários: Perfis são públicos, mas dados sensíveis são isolados
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && isFieldUnchanged('cpf') && isFieldUnchanged('role') && isFieldUnchanged('totalXp'));
      
      match /private/sensitive {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // Organizações: Divulgação pública, edição por membros/admin
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isMemberOfOrg(orgId);

      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(orgId) || isOwner(memberId);
      }

      match /transactions/{txId} {
        allow read: if isAdmin() || isMemberOfOrg(orgId);
        allow write: if isServer() || isAdmin(); 
      }
    }

    // Eventos: Coração do sistema, leitura irrestrita
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isSignedIn();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow delete: if isAdmin() || isMemberOfOrg(resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      
      match /setores/{sectorId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        
        match /assentos/{seatId} {
          allow read: if true;
          allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        }
      }
    }

    // Categorias: Essencial para navegação
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ingressos: Leitura pública para validação de ticketCode
    match /registrations/{regId} {
      allow read: if true; 
      allow create: if isServer();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId) || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // Pedidos: Restrito ao comprador e admin
    match /orders/{orderId} {
      allow read: if isServer() || isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isServer() || isAdmin();
    }

    // Ocorrências Recorrentes
    match /recurring_occurrences/{occId} {
      allow read: if true;
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow create: if isServer() || isAdmin() || isMemberOfOrg(request.resource.data.organizationId);
    }

    // Financeiro e Carteiras
    match /wallets/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow write: if isServer() || isAdmin();
    }

    match /wallet_transactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isServer() || isAdmin();
    }

    match /payout_requests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isSignedIn();
    }

    // ERP e Faturamento
    match /tax_tickets/{id} { allow read: if isAdmin(); allow write: if isServer(); }
    match /tax_ads/{id} { allow read: if isAdmin(); allow write: if isServer(); }
    match /financial_logs/{id} { allow read: if isAdmin(); allow create: if isServer() || isAdmin(); }

    // Anúncios e Promoções
    match /ads/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isServer() || isAdmin() || isMemberOfOrg(resource.data.organizationId);
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin() || isMemberOfOrg(request.resource.data.organizationId);
    }

    // Suporte e Notificações
    match /support_tickets/{id} { 
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); 
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow create: if true; 
      allow update: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.targetUid == request.auth.uid || isAdmin());
    }

    // Configurações e Logs de Sistema
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if true; allow update: if isAdmin(); }
    match /usernames/{username} { allow read: if true; allow write: if isSignedIn() || isServer(); }
    match /sent_emails/{id} { allow read: if isAdmin(); allow create: if isServer(); }
    
    // Gamificação
    match /user_gamification/{uid} { allow read: if true; allow write: if isServer() || isAdmin() || isOwner(uid); }
    match /xp_logs/{id} { allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); allow write: if isServer() || isAdmin(); }

    // Social
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.followerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.followerId;
    }

    // Suporte para Collection Group queries
    match /{path=**}/members/{memberId} {
      allow read: if true;
    }
    match /{path=**}/partners/{partnerId} {
      allow read: if true;
    }
  }
}