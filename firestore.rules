
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // --- REGRAS POR COLEÇÃO ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /private/sensitive {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isMemberOfOrg(orgId);

      match /members/{memberId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(orgId) || (isSignedIn() && memberId == request.auth.uid);
      }

      match /transactions/{txId} {
        allow read: if isAdmin() || isMemberOfOrg(orgId);
        allow write: if isAdmin(); 
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isSignedIn();
      allow update, delete: if isAdmin() || isMemberOfOrg(resource.data.organizationId);

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
      
      match /setores/{sectorId} {
        allow read: if true;
        allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        
        match /assentos/{seatId} {
          allow read: if true;
          allow write: if isAdmin() || isMemberOfOrg(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId);
        }
      }
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.userId || isMemberOfOrg(resource.data.organizationId)));
      allow create: if isAdmin();
      allow update: if isAdmin() || isMemberOfOrg(resource.data.organizationId) || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /recurring_occurrences/{occId} {
      allow read: if true;
      allow update: if isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow create: if isAdmin();
    }

    match /user_gamification/{uid} { 
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == uid); 
    }
    
    match /xp_logs/{id} { 
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); 
      allow write: if isAdmin(); 
    }
    
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.followerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.followerId;
    }

    match /financial_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    match /tax_tickets/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /tax_ads/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /internal_expenses/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    
    match /ads/{id} {
      allow read: if true;
      allow create: if isAdmin() || isSignedIn();
      allow update: if isAdmin() || isMemberOfOrg(resource.data.organizationId);
      allow delete: if isAdmin() || isMemberOfOrg(resource.data.organizationId);
    }

    match /ad_coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /support_tickets/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }
    
    match /usernames/{username} { 
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /password_reset_codes/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /system_logs/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); allow update: if isAdmin(); }
    match /sent_emails/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /wallets/{uid} { allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin()); allow write: if isAdmin(); }
    match /wallet_transactions/{id} { allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin()); allow write: if isAdmin(); }
    match /payout_requests/{id} { allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin()); allow write: if isAdmin(); }

    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // --- REGRAS DE COLLECTION GROUP (Consultas Globais) ---
    match /{path=**}/partners/{partnerId} {
      allow read: if true;
    }
    
    match /{path=**}/members/{memberId} {
      allow read: if true;
    }

    match /{path=**}/transactions/{txId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }
  }
}
