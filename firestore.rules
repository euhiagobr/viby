
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read their own data and admins can read all user data
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId;
    }

    // Organizations can be read by anyone, but only written to by admins
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Affiliate profiles can only be read by the user themselves or an admin.
    // Users can only update specific, non-critical fields.
    match /affiliate_profiles/{userId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create: if request.auth.uid == userId;
        allow update: if request.auth.uid == userId &&
                      request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['payoutDetails']); // Example field
        allow delete: if false; // Nobody can delete profiles
    }

    // Affiliate commissions can only be read by the affiliate or an admin.
    // No one but admins can create, update, or delete commissions directly.
    match /affiliate_commissions/{commissionId} {
        allow read: if get(/databases/$(database)/documents/affiliate_commissions/$(commissionId)).data.affiliateId == request.auth.uid || isAdmin();
        allow create, update, delete: if isAdmin();
    }

    // Affiliate payouts can be created by the user, and read by the user or an admin.
    // Users cannot update or delete their payout requests.
    match /affiliate_payouts/{payoutId} {
        allow create: if request.auth.uid == request.resource.data.userId;
        allow read: if request.auth.uid == resource.data.userId || isAdmin();
        allow update, delete: if isAdmin();
    }

    // Affiliate codes can be read by anyone but only created/modified by server-side processes (admins).
    match /affiliateCodes/{code} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // General catch-all to deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
