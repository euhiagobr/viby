rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE SEGURANÇA ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é administrador global de forma robusta
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Garante que o usuário não está bloqueado (resiliente a documentos inexistentes)
    function isNotBlocked() {
      return !isSignedIn() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'Ativo') != 'Bloqueado';
    }

    // --- REGRA DE OURO (SUPERUSER) ---
    // Administradores globais têm acesso total a qualquer documento
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- REGRAS DE COLEÇÃO ---

    // 1. CONSULTA DE GRUPO (MEMBROS)
    // Essencial para o Dashboard listar as organizações que o usuário participa
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId);
    }

    // 2. ACESSO PÚBLICO (DESCOBERTA)
    match /settings/{docId} { allow read: if true; }
    match /categories/{catId} { allow read: if true; }
    match /usernames/{username} { allow read: if true; }
    match /events/{eventId} { allow read: if true; }
    match /organizations/{orgId} { allow read: if true; }
    match /users/{userId} { allow read: if true; }
    match /ads/{adId} { allow read: if true; }
    match /badges/{badgeId} { allow read: if true; }
    match /levels/{levelId} { allow read: if true; }
    match /xp_rules/{ruleId} { allow read: if true; }
    match /recurring_occurrences/{docId} { allow read: if true; }

    // 3. USUÁRIOS
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && isNotBlocked() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'totalXp', 'level'
        ]);

      match /private/sensitive {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 4. ORGANIZAÇÕES
    match /organizations/{orgId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isSignedIn() && isNotBlocked();

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isNotBlocked();
      }
      
      match /transactions/{txId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // 5. EVENTOS E BILHETERIA
    match /events/{eventId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isSignedIn() && isNotBlocked();
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
      }

      match /interests/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 6. REGISTROS, FINANCEIRO E LOGS
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /wallets/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /payout_requests/{docId} {
      allow read, create: if isSignedIn();
    }

    match /support_tickets/{ticketId} {
      allow read, create: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow update: if isSignedIn();
    }
    
    match /system_logs/{logId} {
      allow create: if true; 
    }

    match /user_gamification/{userId} {
      allow read: if true;
    }
    
    match /xp_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
    }
  }
}