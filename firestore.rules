rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNÇÕES DE APOIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário autenticado é um Administrador Global
    // Utiliza .get() com fallback para evitar erros de campo inexistente
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    // Garante que o usuário não está bloqueado
    // Ignora a trava para administradores
    function isNotBlocked() {
      if (isAdmin()) return true;
      if (!isSignedIn()) return true;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.get('status', 'Ativo') != 'Bloqueado';
    }

    // Verifica cargo em uma organização específica
    function hasOrgRole(orgId, roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in roles;
    }

    // --- REGRAS DE ACESSO ---

    // 1. REGRA DE OURO (SUPERUSER): Admin Global tem poder total
    // Deve ser a primeira regra avaliada para garantir acesso ao /admin/
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // 2. Acesso Público (Leitura)
    // Essencial para Landing Page e Descoberta sem erros de permissão
    match /settings/{docId} { allow read: if true; }
    match /categories/{catId} { allow read: if true; }
    match /usernames/{username} { allow read: if true; }
    match /events/{eventId} { allow read: if true; }
    match /organizations/{orgId} { allow read: if true; }
    match /recurring_events/{docId} { allow read: if true; }
    match /recurring_occurrences/{docId} { allow read: if true; }
    match /ads/{adId} { allow read: if true; }
    match /users/{userId} { allow read: if true; }
    match /user_gamification/{userId} { allow read: if true; }

    // 3. Usuários (Gestão de Perfil)
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && isNotBlocked() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'status', 'plan', 'verified', 'walletBalance', 'adminFlags', 'permissions', 'totalXp', 'level'
        ]);

      match /private/sensitive {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 4. Organizações
    match /organizations/{orgId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isNotBlocked() && (
          (hasOrgRole(orgId, ['owner']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verified', 'status', 'plan', 'ownerId', 'permissions'])) ||
          (hasOrgRole(orgId, ['admin']) && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'ownerId', 'verified', 'plan', 'stripeAccountId', 
             'payoutSettings', 'financialSettings', 'permissions', 'status'
           ]))
        );

      match /members/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && (request.auth.uid == userId || hasOrgRole(orgId, ['owner', 'admin']));
      }
    }

    // 5. Eventos e Bilheteria
    match /events/{eventId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow update: if isNotBlocked() && hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor']);
      
      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn() && (hasOrgRole(resource.data.inviterOrgId, ['owner', 'admin']) || hasOrgRole(partnerId, ['owner', 'admin']));
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked();
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // 6. Registros e Transações (Protegidos)
    match /registrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || (resource.data.keys().contains('organizationId') && hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin', 'finance'])));
      allow update: if isSignedIn() && (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'editor', 'checkin']));
    }

    match /wallets/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /payout_requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    // 7. Auditoria e Suporte
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'protocol']);
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.followerId || request.auth.uid == resource.data.followerId);
    }
  }
}