        "commissionType": "fixed (inicialmente)",
        "commissionValue": "number (valor por ingresso)",
        "active": "boolean",
        "createdAt": "timestamp"
      }
    },
    "affiliateCommissions": {
      "description": "Registro individual de comissões geradas por vendas.",
      "fields": {
        "affiliateUserId": "string",
        "affiliateCode": "string",
        "organizationId": "string",
        "eventId": "string",
        "orderId": "string",
