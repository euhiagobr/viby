
{
  "database": "eventosviby",
  "collections": {
    "events": {
      "fields": {
        "ticketMode": "string ('none' | 'free' | 'paid_single' | 'batches')",
        "mapMode": "string ('none' | 'setores' | 'assentos' | 'mesas')",
        "possuiMapa": "boolean",
        "palcoNome": "string",
        "palcoPosX": "number",
        "palcoPosY": "number",
        "palcoWidth": "number",
        "palcoHeight": "number",
        "capacidadeTotal": "number",
        "loteAtual": "number",
        "batches": "array (com migração de sobras)",
        "address": "object",
        "status": "string"
      },
      "subcollections": {
        "setores": {
          "id": "auto-id",
          "fields": {
            "nome": "string",
            "tipo": "string ('livre' | 'assentos' | 'mesas')",
            "preco": "number",
            "capacidade": "number",
            "linkedTicketName": "string (vínculo dinâmico)",
            "posX": "number",
            "posY": "number",
            "width": "number",
            "height": "number",
            "zIndex": "number",
            "cor": "string",
            "formatoVisual": "string"
          },
          "subcollections": {
            "assentos": {
              "fields": {
                "codigo": "string",
                "status": "string",
                "reservadoPor": "string",
                "reservadoAte": "timestamp"
              }
            }
          }
        }
      }
    }
  }
}
