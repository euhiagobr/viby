
{
  "collections": {
    "events": {
      "fields": {
        "title": "string",
        "description": "string",
        "startDate": "timestamp",
        "endDate": "timestamp",
        "ticketMode": "none | free | paid_single | batches",
        "hasMap": "boolean",
        "mapMode": "none | setores | assentos | mesas",
        "autoHalfPrice": "boolean (60/40 rule)",
        "capacidadeTotal": "number",
        "batches": [
          {
            "id": "string",
            "name": "string",
            "salesStart": "timestamp",
            "salesEnd": "timestamp",
            "price": "number",
            "initialCapacity": "number",
            "currentCapacity": "number",
            "sold": "number",
            "migratedFromPrevious": "number"
          }
        ]
      }
    },
    "registrations": {
      "fields": {
        "eventId": "string",
        "userId": "string",
        "ticketCode": "string",
        "ticketType": "inteira | meia",
        "paymentStatus": "Pendente | Pago",
        "checkedIn": "boolean",
        "seatId": "string (opcional)",
        "sectorId": "string (opcional)",
        "batchId": "string"
      }
    },
    "setores": {
      "path": "events/{eventId}/setores/{sectorId}",
      "fields": {
        "nome": "string",
        "tipo": "livre | assentos | mesas",
        "capacidade": "number",
        "linkedBatchIds": "array",
        "posX": "number",
        "posY": "number"
      }
    },
    "assentos": {
      "path": "events/{eventId}/setores/{sectorId}/assentos/{seatId}",
      "fields": {
        "codigo": "string",
        "status": "disponivel | reservado | vendido | bloqueado",
        "reservadoPor": "string",
        "reservadoAte": "timestamp"
      }
    }
  }
}
