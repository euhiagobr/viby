{
  "collections": {
    "organizations/{orgId}/menu_sections": {
      "description": "Seções de agrupamento do cardápio (ex: Bebidas, Sobremesas).",
      "fields": {
        "id": "string (auto-id)",
        "nome": "string (obrigatório)",
        "ordem": "number (para ordenação visual)",
        "updatedAt": "timestamp"
      }
    },
    "organizations/{orgId}/menu_items": {
      "description": "Itens individuais do cardápio vinculados a uma organização e seção.",
      "fields": {
        "id": "string (auto-id)",
        "sectionId": "string (ref: menu_sections)",
        "nome": "string (obrigatório)",
        "descricao": "string (longa)",
        "valor": "number (float, obrigatório)",
        "priceDisplayMode": "string ('value' | 'consult' | 'hidden', default: 'value')",
        "imageUrl": "string (url)",
        "featured": "boolean (default: false)",
        "porcao": "string (ex: 500ml)",
        "serves": "string (ex: '1 pessoa', '2 pessoas')",
        "temAlergenicos": "boolean",
        "alergenicos": "array of strings",
        "promocional": "boolean",
        "valorPromocional": "number (opcional)",
        "promoInicio": "timestamp (opcional, UTC-3)",
        "promoFim": "timestamp (opcional, UTC-3)",
        "ordem": "number (para ordenação visual)",
        "updatedAt": "timestamp"
      }
    }
  }
}
