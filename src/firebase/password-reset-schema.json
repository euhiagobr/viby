
{
  "collection": "password_reset_codes",
  "description": "Armazenamento de códigos OTP para recuperação de senha",
  "fields": {
    "email": "string (indexado)",
    "code": "string (6 caracteres alfanuméricos)",
    "createdAt": "serverTimestamp",
    "expiresAt": "timestamp",
    "used": "boolean",
    "usedAt": "timestamp",
    "attempts": "number (máx 5)",
    "ip": "string",
    "userAgent": "string"
  }
}
