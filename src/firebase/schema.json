
{
  "collections": {
    "users": {
      "id": "UID do Auth",
      "fields": {
        "username": "string (único global)",
        "displayName": "string",
        "email": "string",
        "avatar": "url",
        "bio": "string",
        "cpf": "string (AES CTR encrypted)",
        "gender": "masculino | feminino | etc",
        "birthDate": "string (YYYY-MM-DD)",
        "city": "string",
        "state": "string",
        "country": "string",
        "plan": "free | pro | top",
        "createdAt": "timestamp"
      }
    },
    "organizations": {
      "id": "auto-id",
      "fields": {
        "username": "string (único global)",
        "name": "string",
        "slug": "string",
        "bio": "string",
        "type": "produtora | ong | artista | etc",
        "avatar": "url",
        "verified": "boolean",
        "createdBy": "UID",
        "createdAt": "timestamp"
      }
    },
    "events": {
      "id": "auto-id",
      "fields": {
        "organizationId": "string (ref:organizations)",
        "title": "string",
        "description": "string",
        "ticketMode": "none | free | paid_single | batches",
        "mapMode": "none | setores | assentos | mesas",
        "possuiMapa": "boolean",
        "capacidadeTotal": "number",
        "batches": "array of objects { id, name, startDate, endDate, capacity, ticketTypes: [{ id, name, price, quantity, poolId }] }",
        "palcoNome": "string",
        "palcoPosX": "number",
        "palcoPosY": "number",
        "palcoWidth": "number",
        "palcoHeight": "number",
        "status": "string",
        "createdAt": "timestamp"
      },
      "subcollections": {
        "setores": {
          "fields": {
            "nome": "string",
            "tipo": "livre | assentos | mesas",
            "capacidade": "number",
            "linkedBatchIds": "array of strings",
            "linkedTicketIds": "array of strings",
            "cor": "string",
            "posX": "number",
            "posY": "number",
            "width": "number",
            "height": "number",
            "rotation": "number",
            "zIndex": "number"
          }
        },
        "assentos": {
          "path": "events/{eventId}/setores/{sectorId}/assentos/{seatId}",
          "fields": {
            "codigo": "string",
            "status": "disponivel | reservado | vendido | bloqueado",
            "reservadoPor": "string (userId)",
            "reservadoAte": "timestamp",
            "ingressoId": "string (registrationId)",
            "categoria": "string (comum | pcd | etc)"
          }
        }
      }
    },
    "registrations": {
      "fields": {
        "eventId": "string",
        "userId": "string",
        "ticketCode": "string",
        "paymentStatus": "string",
        "checkedIn": "boolean",
        "seatId": "string",
        "sectorId": "string",
        "batchId": "string",
        "ticketTypeId": "string"
      }
    },
    "usernames": {
      "id": "username (lower)",
      "fields": {
        "uid": "ID do dono (user ou org)",
        "type": "user | organization"
      }
    }
  }
}
