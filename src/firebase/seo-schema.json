{
  "seo_config": {
    "dynamic_metadata": {
      "pages": ["Eventos", "Perfis", "Home"],
      "tags": ["title", "description", "canonical", "OG", "Twitter"]
    },
    "structured_data": {
      "events": "https://schema.org/Event",
      "organizations": "https://schema.org/Organization",
      "people": "https://schema.org/Person"
    },
    "sitemap": {
      "path": "/sitemap.xml",
      "frequency": "hourly cache",
      "entities": ["static_routes", "profiles", "active_events"]
    },
    "robots": {
      "path": "/robots.txt",
      "rules": "standard index allow with admin exclusions"
    }
  }
}