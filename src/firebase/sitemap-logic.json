{
  "audit_version": "2.1.0",
  "subject": "Arquitetura Consolidada de Sitemaps",
  "pipeline_flow": [
    "Load Raw Data (Firestore usernames/events)",
    "Resolve Canonical Username (isValidUsername check)",
    "Block Numeric IDs (Regex check)",
    "Global Deduplication (Set-based comparison)",
    "Empty State Fallback (Homepage insertion)",
    "XML Response Generation"
  ],
  "collections_involved": {
    "usernames": "Fonte primária para sitemap-users.xml",
    "events": "Fonte primária para sitemap-events.xml (Filtro: status=='Ativo')",
    "cityPages": "Fonte para sitemap-cities.xml"
  },
  "constraints": {
    "base_url": "https://viby.club",
    "no_numeric_ids": "Bloqueia /123456789",
    "no_reserved_routes": "Bloqueia /admin, /dashboard, etc no lugar de usernames",
    "index_only_entry": "/sitemap.xml"
  }
}
