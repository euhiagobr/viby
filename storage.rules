rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regras do Viby Club: Leitura Pública total e Escrita para Autenticados
    match /viby/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Suporte para o bucket específico 'viby' caso o projeto o utilize explicitamente
    match /b/viby/o {
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // Regras da ONG (Mantidas conforme original)
    match /ong/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}