
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // DEPLOY VIBY - Versão: 1.5.0 (Acesso Público Total Garantido)
    // Forçando liberação total de leitura e escrita em TODOS os buckets, incluindo o bucket 'viby'.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
