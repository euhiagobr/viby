
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && firestore.exists(/databases/(default)/documents/system_admins/$(request.auth.uid));
    }

    // --- ACESSO PÚBLICO (Leitura liberada para assets e mídias de vitrine) ---

    // Branding, Logos e Assets de Identidade
    match /admin/site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brand-assets/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Mídias de Usuários, Organizações e Eventos (Públicas)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /experiences/{experienceId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /city-covers/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /city-covers-manual/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ACESSO PRIVADO (Protegido por UID ou Admin) ---

    match /support/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /verification/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /payout_proofs/{orgId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
