
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regras do Viby Club
    // Suporta tanto a pasta /viby/ no bucket padrão quanto o bucket nomeado 'viby'
    match /viby/{allPaths=**} {
      allow read: if true; // Imagens de eventos são públicas para visualização
      allow write: if request.auth != null && 
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.platform == "viby";
    }
    
    // Caso o bucket secundário se chame literalmente 'viby'
    match /b/viby/o {
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null && 
          get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.platform == "viby";
      }
    }
    
    // Regras da ONG (Mantidas isoladas no bucket default na pasta /ong/)
    match /ong/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}
