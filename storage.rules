
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        firestore.exists(/databases/(default)/documents/system_admins/$(request.auth.uid))
      );
    }

    // --- ACESSO PÚBLICO (Leitura liberada para assets de UI) ---

    // Branding do Site (Logotipo, Favicon, Banners da Home)
    match /admin/site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Material de Marca / Media Kit
    match /brand-assets/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Capas de Cidades
    match /city-covers/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /city-covers-manual/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Imagens de Usuários, Organizações e Eventos (Públicas para a vitrine)
    match /users/{userId}/avatar {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // --- ACESSO PRIVADO (Protegido por UID ou Admin) ---

    match /support/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /verification/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /payout_proofs/{orgId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
