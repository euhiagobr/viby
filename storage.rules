
rules_version = '2';
service firebase.storage {
  match /b/ong-desafios-3942a.firebasestorage.app/o {
    // REGRAS ONG - Versão: 2.0.0 (Isolamento de Segurança)
    // Proteção dos dados da ONG: apenas usuários autenticados podem ler/escrever
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
