
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Regra Global de Leitura (Assets Públicos)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Pasta Administrativa - Bypass total para Super Admin
    match /admin/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Pasta de Ads
    match /ads/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }

    // Usuários - Proteção de Perfil
    match /users/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isOwner(userId);
    }

    // Organizações e Eventos
    match /organizations/{orgId}/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }

    match /events/{eventId}/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }
    
    // Suporte
    match /support/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isOwner(userId);
    }

    // Comprovantes Financeiros
    match /payout_proofs/{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}
