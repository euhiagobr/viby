
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- FUNÇÕES DE AUXÍLIO ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Função central de autorização administrativa para o Storage
    // Adicionado check direto de UID mestre para máxima resiliência
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        request.auth.token.admin == true ||
        firestore.exists(/databases/(default)/documents/system_admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Regra Global de Leitura (Pública para vitrines e SEO)
    match /{allPaths=**} {
      allow read: if true;
    }

    // --- PASTA ADMINISTRATIVA ---
    // Permite gravação total para quem é admin na pasta /admin/
    match /admin/{allPaths=**} {
      allow write: if isAdmin();
    }

    // --- PASTAS DE USUÁRIOS E ORGANIZAÇÕES ---
    match /users/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isOwner(userId);
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }

    match /events/{eventId}/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }
    
    match /ads/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }
    
    match /support/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId);
    }

    match /payout_proofs/{orgId}/{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}
