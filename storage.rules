rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /viby/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/eventosviby/documents/users/$(request.auth.uid)).data.platform == "viby";
    }
    match /ong/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}