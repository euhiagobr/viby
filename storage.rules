
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        firestore.exists(/databases/(default)/documents/system_admins/$(request.auth.uid)) ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- REGRAS DE MATERIAL DE MARCA VIBY ---
    match /brand-assets/{file} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- REGRAS DE CAPAS DE CIDADES ---
    match /city-covers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /city-covers-manual/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- REGRAS PÚBLICAS ---
    match /admin/site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/avatar {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /organizations/{orgId}/{type} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // --- REGRAS PRIVADAS ---
    match /support/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /verification/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /payout_proofs/{orgId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
