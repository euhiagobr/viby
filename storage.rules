
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // DEPLOY VIBY - Versão: 1.4.0 (Acesso Público Total Garantido)
    // Este deploy força a liberação de leitura e escrita em todos os buckets do projeto.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
