rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOfOrg(orgId) {
      // Nota: No Storage, a verificação de documento do Firestore é assíncrona e tem custo de rede.
      // Permitimos a escrita baseada na estrutura de pastas autenticada.
      return isSignedIn();
    }

    // Leitura pública para todos os assets da plataforma (Imagens de eventos, banners, avatares)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Identidade Pessoal: Apenas o dono pode fazer upload na sua pasta
    match /users/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }

    // Configurações Administrativas: Exige login (Apenas admin via backend/dashboard)
    match /admin/{allPaths=**} {
      allow write: if isSignedIn();
    }

    // Identidade de Marca: Exige login
    match /organizations/{orgId}/{allPaths=**} {
      allow write: if isSignedIn();
    }

    // Conteúdo de Eventos: Exige login
    match /events/{eventId}/{allPaths=**} {
      allow write: if isSignedIn();
    }
    
    // Anúncios: Exige login
    match /ads/{allPaths=**} {
      allow write: if isSignedIn();
    }
    
    // Suporte: Exige login
    match /support/{userId}/{allPaths=**} {
      allow write: if isOwner(userId);
    }
  }
}