
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Função robusta de verificação administrativa sincronizada com Firestore
    function isAdmin() {
      return isSignedIn() && (
        // 1. UID Mestre para Bootstrap
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        // 2. Custom Claims
        request.auth.token.admin == true ||
        // 3. Coleção dedicada de admins (Mais performático no Storage)
        firestore.exists(/databases/(default)/documents/system_admins/$(request.auth.uid)) ||
        // 4. Role no documento de usuário
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read: if true;
    }

    // Escrita administrativa centralizada
    match /admin/{allPaths=**} {
      allow write: if isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isOwner(userId);
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }

    match /events/{eventId}/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }
    
    match /ads/{allPaths=**} {
      allow write: if isAdmin() || isSignedIn();
    }
    
    match /support/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId);
    }

    match /payout_proofs/{orgId}/{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}
