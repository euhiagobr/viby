
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // DEPLOY VIBY - Versão: 1.6.0 (Acesso Público Total Garantido em múltiplos buckets)
    // Esta regra permite leitura e escrita pública em todos os arquivos para depuração.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
