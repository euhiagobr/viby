rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Leitura pública para todos os assets da plataforma
    match /{allPaths=**} {
      allow read: if true;
    }

    // Identidade Pessoal
    match /users/{userId}/{allPaths=**} {
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Configurações Administrativas (Logo, Ícones)
    match /admin/{allPaths=**} {
      allow write: if isSignedIn();
    }

    // Identidade de Marca
    match /organizations/{orgId}/{allPaths=**} {
      allow write: if isSignedIn();
    }

    // Conteúdo de Eventos
    match /events/{eventId}/{allPaths=**} {
      allow write: if isSignedIn();
    }
    
    // Anúncios
    match /ads/{allPaths=**} {
      allow write: if isSignedIn();
    }
  }
}
