
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "AqTVL8VRTZT435pZudkObzMGsrR2" ||
        firestore.get(/databases/(default)/documents/system_admins/$(request.auth.uid)).data.status == 'Ativo'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS PÚBLICAS (Mídias de Feed) ---
    
    match /admin/site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/avatar {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /organizations/{orgId}/{type} {
      // type can be 'avatar' or 'banner'
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /ads/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // --- REGRAS PRIVADAS (Documentos e Suporte) ---

    match /support/{userId}/{allPaths=**} {
      // Tickets e arquivos de chat de suporte
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /verification/{userId}/{allPaths=**} {
      // Documentos de solicitação de remoção ou verificação de identidade
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /payout_proofs/{orgId}/{allPaths=**} {
      // Comprovantes de transferências bancárias
      allow read: if isAdmin() || (isSignedIn() && firestore.get(/databases/(default)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['owner', 'admin', 'finance']);
      allow write: if isAdmin();
    }
    
    match /expenses/{userId}/{allPaths=**} {
      // Comprovantes de despesas internas lançadas pelo admin
      allow read, write: if isAdmin();
    }
  }
}
