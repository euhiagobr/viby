
rules_version = '2';
service firebase.storage {
  match /b/viby/o {
    // REGRAS VIBY - Versão: 2.0.0
    // Isolamento para o bucket exclusivo 'viby'
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Assets globais da marca
    match /site_assets/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Fotos de perfil
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Fotos de eventos
    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Outros arquivos do sistema Viby
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
