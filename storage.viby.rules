rules_version = '2';
service firebase.storage {
  match /b/viby/o {
    // VIBY STORAGE ISOLATION
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /site_assets/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn(); // Admin check handled via client logic + firestore rules
    }

    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}