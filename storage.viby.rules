rules_version = '2';
service firebase.storage {
  // REGRAS STORAGE VIBY - Versão: 1.9.0
  // Bucket: viby
  match /b/viby/o {
    
    // Assets do site (logos e ícones) - Leitura pública para identidade visual
    match /site_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; 
    }

    // Avatares de perfil
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Imagens de eventos
    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra padrão
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}