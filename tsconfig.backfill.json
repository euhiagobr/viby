{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "./dist",
    "declaration": false
  },
  "ts-node": {
    "esm": true,
    "experimentalEsm": true,
    "compilerOptions": {
      "module": "ES2020",
      "moduleResolution": "node",
      "allowImportingTsExtensions": true
    }
  },
  "include": ["scripts/backfill*.ts", "scripts/validate*.ts", "scripts/rollback*.ts"],
  "exclude": ["node_modules"]
}
